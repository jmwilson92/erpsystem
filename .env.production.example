# ── ForgeRP production environment ─────────────────────────────
# Copy to .env  (cp .env.production.example .env)  then fill in.
# NEVER commit real secrets.

# Your domain — Caddy fetches + renews TLS for it automatically.
# Point this hostname's DNS A record at the server first.
DOMAIN=erp.example.com

# Database — SQLite volume (Docker default) or Postgres URL
DATABASE_URL="file:/data/forgerp.db"
# DATABASE_URL="postgresql://forgeerp:CHANGE_ME@db:5432/forgeerp?schema=public"

# REQUIRED for production: login required, no persona switcher.
DEMO_MODE=0

# First-boot data:
#   prod = chart of accounts, UOMs, permissions, approval pipeline,
#          default settings — NO demo content (recommended for a plant)
#   1    = full demo dataset      0 = completely empty
SEED_ON_FIRST_BOOT=prod

# Public URL (invite links, QR labels). Usually https:// + your DOMAIN.
NEXT_PUBLIC_APP_URL=https://erp.example.com

# ── Email delivery (invites / password resets) ─────────────────
# Free key from resend.com. Without it, invite links still work — the
# admin copies them from the audit log instead of them being emailed.
RESEND_API_KEY=
EMAIL_FROM=erp@example.com

# ── Live company bank feeds (Plaid) ────────────────────────────
# Free keys from dashboard.plaid.com. Leave blank to keep file/CSV/OFX
# import only. PLAID_ENV: sandbox (fake test banks) until Plaid approves
# your app for production access to real institutions.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Optional AI assistant upgrade
# XAI_API_KEY=
# XAI_MODEL=grok-2-latest

# ONLY for intentional public marketing demo hosts (keeps DEMO_MODE on)
# ALLOW_DEMO_IN_PRODUCTION=1

# Node
NODE_ENV=production
PORT=3000
