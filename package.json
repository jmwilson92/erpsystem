{
  "name": "forgeerp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "prisma generate && prisma db push",
    "dev": "next dev --turbopack",
    "prestart": "prisma generate && prisma db push",
    "build": "next build",
    "prebuild": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "sync": "prisma generate && prisma db push",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:prod": "tsx prisma/seed-prod.ts",
    "predb:reset": "node -e \"const fs=require('fs');for(const f of ['prisma/dev.db','prisma/dev.db-wal','prisma/dev.db-shm'])try{fs.rmSync(f)}catch{};try{fs.rmSync('prisma/sandboxes',{recursive:true,force:true})}catch{}\"",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "setup": "prisma generate && prisma db push && tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke-unit.ts",
    "assert:prod-env": "node scripts/assert-production-env.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "verify": "tsx scripts/verify/run-all.ts",
    "verify:svc": "tsx scripts/verify/run-all.ts --skip-http",
    "verify:keys": "node scripts/verify-integrations.mjs",
    "stripe:setup-plans": "node scripts/stripe-setup-plans.mjs",
    "verify:http": "tsx scripts/verify/chunk-j-http.ts",
    "verify:money": "tsx scripts/verify/chunk-c2-money-path.ts",
    "verify:serials": "tsx scripts/verify/chunk-serials-rma.ts",
    "verify:chunk": "tsx scripts/verify/run-all.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-hover-card": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-navigation-menu": "^1.2.18",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.2",
    "fuse.js": "^7.4.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.23.0",
    "next": "15.5.20",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20.19"
  }
}
