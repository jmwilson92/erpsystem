// ForgeRP — Manufacturing ERP Schema
// SQLite for zero-config local dev; switch to PostgreSQL via docker-compose

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ═══════════════════════════════════════════════════════════════
// CORE / AUTH / AUDIT
// ═══════════════════════════════════════════════════════════════

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  role          String   @default("OPERATOR") // ADMIN, ENGINEERING, CM, QUALITY, PURCHASING, PRODUCTION, ACCOUNTING, HR, VIEWER, OPERATOR
  department    String?
  title         String?
  skills        String?  // JSON array
  certifications String? // JSON array with expiry dates
  avatarUrl     String?
  /// Direct manager (org chart) — drives the manager approvals queue
  /// and the "My Team" view in HR.
  managerId     String?
  manager       User?    @relation("OrgChart", fields: [managerId], references: [id], onDelete: SetNull)
  reports       User[]   @relation("OrgChart")
  // Shop-floor sign-off PIN (demo: 4–6 digits). Required on WI step sign-off.
  pinCode       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  auditLogs           AuditLog[]
  timeEntries         TimeEntry[]
  ptoRequests         PtoRequest[]
  expenseReports      ExpenseReport[]
  performanceReviews  PerformanceReview[]      @relation("ReviewSubject")
  reviewsGiven        PerformanceReview[]      @relation("Reviewer")
  goals               EmployeeGoal[]
  assetsHeld          Asset[]                  @relation("AssetHolder")
  assetCheckouts      AssetCheckout[]          @relation("AssetCheckoutUser")
  goalCheckIns        GoalCheckIn[]            @relation("GoalCheckInAuthor")
  feedbackReceived    FeedbackNote[]           @relation("FeedbackAbout")
  feedbackGiven       FeedbackNote[]           @relation("FeedbackAuthor")
  trainingRecords     TrainingRecord[]
  employeeDocuments   EmployeeDocument[]
  timesheets          Timesheet[]
  timesheetApprovals  TimesheetApproval[]
  assignedWorkOrders  WorkOrder[]              @relation("WOAssignee")
  createdWorkOrders   WorkOrder[]              @relation("WOCreator")
  stepSignOffs        WorkInstructionSignOff[]
  wiCreated           WorkInstruction[]        @relation("WICreator")
  testProceduresCreated TestProcedure[]        @relation("TestProcCreator")
  approvals           Approval[]
  engTicketsAssigned  EngineeringTicket[]      @relation("TicketAssignee")
  engTicketsCreated   EngineeringTicket[]      @relation("TicketCreator")
  ncrsCreated         NonConformance[]         @relation("NCRCreator")
  mrbDecisions        MrbDisposition[]
  carActivityLogs     CarActivityLog[]
  projectMemberships  ProjectMember[]
  productsOwned       Product[]              @relation("ProductOwner")
  productsEngLead     Product[]              @relation("ProductEngLead")
  productsCmOwned     Product[]              @relation("ProductCmOwner")
  productMemberships  ProductMember[]
  productLifecycleEvents ProductLifecycleEvent[]
  programsOwned       Program[]              @relation("ProgramOwner")
  projectsSponsored   Project[]              @relation("ProjectSponsor")
  projectsManaged     Project[]              @relation("ProjectManager")
  wikiPagesEdited     ProjectWikiPage[]
  permissionGroups    UserPermissionGroup[]
  userPermissions     UserPermission[]
  gfpCheckedOut       GovernmentProperty[]   @relation("GfpCheckedOut")
  gfpAudits           GfpAuditRecord[]       @relation("GfpAuditor")
  gfpCheckouts        GfpCheckout[]          @relation("GfpCheckoutUser")
  gfpCheckins         GfpCheckout[]          @relation("GfpCheckinUser")
  gfpConsumptionsRequested GfpConsumption[]  @relation("GfpConsumptionRequester")
  gfpConsumptionsApproved  GfpConsumption[]  @relation("GfpConsumptionApprover")
  virtualAssetsAssigned    VirtualAsset[]    @relation("VirtualAssetAssignee")
  virtualAssetsCheckedOut  VirtualAsset[]    @relation("VirtualAssetCheckout")
  virtualAssetAssignments  VirtualAssetAssignment[]
  workCenterStaff     WorkCenterStaff[]
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  changes    String?  // JSON diff
  metadata   String?  // JSON
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([userId])
}

model Approval {
  id          String    @id @default(cuid())
  entityType  String
  entityId    String
  stage       String
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED, SKIPPED
  stepOrder   Int       @default(1)
  minAmount   Float     @default(0)
  policyStepId String?
  policyStep  ApprovalPolicyStep? @relation(fields: [policyStepId], references: [id])
  approverId  String?
  approver    User?     @relation(fields: [approverId], references: [id])
  comments    String?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([status, stepOrder])
}

// Configurable multi-step approval for PRs (threshold-based)
model ApprovalPolicy {
  id          String   @id @default(cuid())
  name        String
  entityType  String   @default("PurchaseRequest")
  description String?
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps       ApprovalPolicyStep[]
  purchaseRequests PurchaseRequest[]
}

model ApprovalPolicyStep {
  id              String @id @default(cuid())
  policyId        String
  policy          ApprovalPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  stepOrder       Int
  name            String // e.g. Buyer review, Manager, Finance
  // Step applies when PR totalEstimate >= minAmount (USD)
  minAmount       Float  @default(0)
  // Who may approve: role and/or specific user
  approverRole    String? // PURCHASING, ACCOUNTING, ADMIN, etc.
  approverUserId  String?
  required        Boolean @default(true)
  createdAt       DateTime @default(now())

  approvals       Approval[]

  @@index([policyId, stepOrder])
}

// ═══════════════════════════════════════════════════════════════
// PARTS / ITEMS / BOM
// ═══════════════════════════════════════════════════════════════

// ── UOM master + conversions ─────────────────────────────────
model UomUnit {
  id          String  @id @default(cuid())
  code        String  @unique // EA, LB, KG, FT, IN, GAL, L, ...
  name        String
  category    String  @default("COUNT") // COUNT, WEIGHT, LENGTH, VOLUME, TIME, OTHER
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parts       Part[]
  wiSteps     WorkInstructionStep[]
  conversionsFrom UomConversion[] @relation("FromUom")
  conversionsTo   UomConversion[] @relation("ToUom")
}

model UomConversion {
  id          String @id @default(cuid())
  fromUomId   String
  fromUom     UomUnit @relation("FromUom", fields: [fromUomId], references: [id], onDelete: Cascade)
  toUomId     String
  toUom       UomUnit @relation("ToUom", fields: [toUomId], references: [id], onDelete: Cascade)
  // multiply from qty by factor to get to qty (1 FT = 12 IN → factor 12)
  factor      Float
  notes       String?

  @@unique([fromUomId, toUomId])
}

model Part {
  id              String   @id @default(cuid())
  partNumber      String   @unique
  description     String
  revision        String   @default("A")
  // Display UOM code (synced with uomUnit when set)
  uom             String   @default("EA")
  uomUnitId       String?
  uomUnit         UomUnit? @relation(fields: [uomUnitId], references: [id])
  // Legacy + compat: MAKE, BUY, PHANTOM, ASSEMBLY
  partType        String   @default("MAKE")
  // PURCHASE → acquire via PO; BUILD → acquire via WO (components may still be purchased)
  sourcingMethod  String   @default("BUILD") // PURCHASE, BUILD
  // Structure class (especially for BUILD items)
  // RAW_MATERIAL | SUB_ASSEMBLY | TOP_LEVEL_ASSEMBLY | N_A
  itemStructure   String   @default("N_A")
  standardCost    Float    @default(0)
  lastBuyCost     Float    @default(0) // last PO unit cost
  averageCost     Float    @default(0) // rolling average
  leadTimeDays    Int      @default(0)
  isSerialized    Boolean  @default(false)
  isLotControlled Boolean  @default(false)
  isActive        Boolean  @default(true)
  drawingNumber   String?
  /// First/primary product photo (auto-filled from first dock receive photo when empty)
  primaryImageUrl String?
  // Accounting ledger assignment (choice only — not posted yet)
  inventoryAccountId String?
  inventoryAccount   Account? @relation("PartInventoryAccount", fields: [inventoryAccountId], references: [id])
  expenseAccountId   String?
  expenseAccount     Account? @relation("PartExpenseAccount", fields: [expenseAccountId], references: [id])
  cogsAccountId      String?
  cogsAccount        Account? @relation("PartCogsAccount", fields: [cogsAccountId], references: [id])
  // Receiving inspection requirements (item card — not BOM)
  requiresGdtInspection   Boolean @default(false)
  requiresFunctionalTest  Boolean @default(false)
  /// Test procedure called out when this part requires a functional test at receiving
  functionalTestProcedureId String?
  functionalTestProcedure   TestProcedure? @relation("PartFunctionalTest", fields: [functionalTestProcedureId], references: [id])
  // Inventory policy / replenishment (item card)
  isKanban        Boolean @default(false) // min/max kanban refill
  minStock        Float   @default(0)     // reorder when on-hand ≤ min
  maxStock        Float   @default(0)     // refill target / max bin
  reorderPoint    Float   @default(0)     // optional classic ROP (if not kanban)
  safetyStock     Float   @default(0)
  abcClass        String? // A | B | C inventory classification
  isCritical      Boolean @default(false) // critical / sole-source flag
  shelfLifeDays   Int?    // optional shelf life for lot expiry
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bomHeaders      BomHeader[]
  bomLines        BomLine[]        @relation("ComponentPart")
  inventoryItems  InventoryItem[]
  poLines         PurchaseOrderLine[]
  workOrders      WorkOrder[]
  workInstructions WorkInstruction[]
  testProcedures  TestProcedure[]   @relation("TestProcPart")
  ncrs            NonConformance[]
  serials         SerialNumber[]
  lots            Lot[]
  salesOrderLines SalesOrderLine[]
  quoteLines      QuoteLine[]
  kitOrderLines   KitOrderLine[]
  receivingPhotos ReceivingPhoto[]
  receivingDocuments ReceivingDocument[]
  travelerLines   ReceivingTravelerLine[]
  vendors         PartVendor[]
  traceEvents     TraceEvent[]
  forecastLines   ForecastLine[]
  mrsLines        MaterialRequisitionLine[]
  cmDocuments     CmDocument[]
  // PLM product links
  productsAsTopLevel Product[]     @relation("ProductTopLevelPart")
  productPartLinks   ProductPart[]
  productVariants    ProductVariant[]
  productionEngIssues ProductionEngIssue[]

  @@index([sourcingMethod])
  @@index([itemStructure])
  @@index([partType])
  @@index([isActive])
  @@index([isKanban])
}

// Vendor catalog lines for purchasable items
model PartVendor {
  id              String  @id @default(cuid())
  partId          String
  part            Part    @relation(fields: [partId], references: [id], onDelete: Cascade)
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id])
  vendorPartNumber String?
  vendorDescription String?
  vendorSku       String?
  manufacturer    String?
  manufacturerPn  String?
  unitCost        Float   @default(0)
  currency        String  @default("USD")
  minOrderQty     Float   @default(1)
  leadTimeDays    Int     @default(0)
  isPreferred     Boolean @default(false)
  isActive        Boolean @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([partId, supplierId, vendorPartNumber])
  @@index([supplierId])
}

model BomHeader {
  id              String   @id @default(cuid())
  partId          String
  part            Part     @relation(fields: [partId], references: [id])
  revision        String
  status          String   @default("DRAFT") // DRAFT, PROTOTYPE, IN_REVIEW, CERTIFIED, OBSOLETE
  description     String?
  isPrototype     Boolean  @default(false)
  certifiedAt     DateTime?
  certifiedById   String?
  effectiveDate   DateTime?
  obsoleteDate    DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lines           BomLine[]
  workOrders      WorkOrder[]
  changeRequests  ChangeRequest[]
  workInstructions WorkInstruction[]
  cmDocuments     CmDocument[]

  @@unique([partId, revision])
  @@index([status])
}

model BomLine {
  id              String  @id @default(cuid())
  bomHeaderId     String
  bomHeader       BomHeader @relation(fields: [bomHeaderId], references: [id], onDelete: Cascade)
  componentPartId String
  componentPart   Part    @relation("ComponentPart", fields: [componentPartId], references: [id])
  quantity        Float
  findNumber      String?
  referenceDesignators String?
  notes           String?
  scrapFactor     Float   @default(0)
  sortOrder       Int     @default(0)
}

// ═══════════════════════════════════════════════════════════════
// WORK INSTRUCTIONS
// ═══════════════════════════════════════════════════════════════

model WorkInstruction {
  id              String   @id @default(cuid())
  documentNumber  String
  revision        String   @default("A")
  title           String
  status          String   @default("DRAFT") // DRAFT, ENGINEERING_REVIEW, CM_REVIEW, RELEASED, OBSOLETE
  partId          String?
  part            Part?    @relation(fields: [partId], references: [id])
  // Link to BOM when released (preferred over free-text bomRevision)
  bomHeaderId     String?
  bomHeader       BomHeader? @relation(fields: [bomHeaderId], references: [id])
  bomRevision     String?
  workCenter      String?
  estimatedMinutes Int?
  // Safety / references / tooling (header-level)
  hazmatRequired  String?  // free text: chemicals, PPE, hazmat classes
  // Primary drawing + additional refs (JSON string[] or newline list stored as text)
  drawingNumber   String?
  drawingReferences String?
  // Required tools: JSON [{ name, partId?, qty, notes }]
  requiredTools   String?
  createdById     String?
  createdBy       User?    @relation("WICreator", fields: [createdById], references: [id])
  releasedAt      DateTime?
  releasedById    String?
  // Released docs are locked; edits require new revision (supersedes chain)
  isLocked        Boolean  @default(false)
  supersedesId    String?
  supersedes      WorkInstruction?  @relation("WiRevisionChain", fields: [supersedesId], references: [id])
  supersededBy    WorkInstruction[] @relation("WiRevisionChain")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  steps           WorkInstructionStep[]
  signOffs        WorkInstructionSignOff[]
  workOrderLinks  WorkOrderInstruction[]
  changeRequests  ChangeRequest[]
  toolPurchaseRequests PurchaseRequest[]
  cmDocuments     CmDocument[]

  @@unique([documentNumber, revision])
  @@index([status])
  @@index([bomHeaderId])
}

/// A CM-controlled test procedure (ATP, functional test, burn-in, etc.).
/// Work-instruction steps and receiving functional-test requirements call
/// these out by reference so the released, revision-controlled procedure
/// is the single source of truth.
model TestProcedure {
  id             String   @id @default(cuid())
  number         String
  revision       String   @default("A")
  title          String
  /// FUNCTIONAL | ATP | BURN_IN | ENVIRONMENTAL | INSPECTION
  category       String   @default("FUNCTIONAL")
  status         String   @default("DRAFT") // DRAFT, CM_REVIEW, RELEASED, OBSOLETE
  partId         String?
  part           Part?    @relation("TestProcPart", fields: [partId], references: [id])
  equipment      String?  // required test equipment / station
  purpose        String?
  acceptanceCriteria String?
  createdById    String?
  createdBy      User?    @relation("TestProcCreator", fields: [createdById], references: [id])
  releasedAt     DateTime?
  releasedById   String?
  isLocked       Boolean  @default(false)
  supersedesId   String?
  supersedes     TestProcedure?  @relation("TpRevisionChain", fields: [supersedesId], references: [id])
  supersededBy   TestProcedure[] @relation("TpRevisionChain")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  steps          TestProcedureStep[]
  wiSteps        WorkInstructionStep[]
  functionalForParts Part[] @relation("PartFunctionalTest")

  @@unique([number, revision])
  @@index([status])
  @@index([partId])
}

model TestProcedureStep {
  id              String  @id @default(cuid())
  testProcedureId String
  testProcedure   TestProcedure @relation(fields: [testProcedureId], references: [id], onDelete: Cascade)
  stepNumber      Int
  parameter       String  // what is measured (e.g. "Idle current draw")
  method          String? // how (e.g. "DMM in series, 28VDC applied")
  spec            String? // nominal / target
  minValue        Float?
  maxValue        Float?
  units           String?
  sortOrder       Int     @default(0)

  @@index([testProcedureId])
}

model WorkInstructionStep {
  id                  String  @id @default(cuid())
  workInstructionId   String
  workInstruction     WorkInstruction @relation(fields: [workInstructionId], references: [id], onDelete: Cascade)
  stepNumber          Int
  title               String
  instructions        String  // rich text / markdown
  // BUILD | QA | TEST — drives station routing defaults and traveler queues
  stepType            String  @default("BUILD")
  isTestStep          Boolean @default(false) // kept for compatibility; true when stepType=TEST
  // Operator must record PASS/FAIL for this step
  passFailRequired    Boolean @default(false)
  testCriteria        String?
  expectedValue       String?
  minValue            Float?
  maxValue            Float?
  // Measurement unit for recordings (VDC, OHM, etc.) — from UomUnit or free code
  measureUom          String?
  measureUomUnitId    String?
  measureUomUnit      UomUnit? @relation(fields: [measureUomUnitId], references: [id])
  // Optional cure / dwell time before next step can be signed
  cureTimeMinutes     Int?
  // Routing: general area and/or specific workcenter (both optional = free)
  requiredArea        String?
  workCenter          String?
  routeLock           Boolean @default(false)
  estimatedMinutes    Int?
  attachmentUrls      String? // JSON array of photos (data URLs or paths)
  mediaUrls           String? // JSON array of recordings / videos
  drawingLinks        String? // JSON array
  requiresSignOff     Boolean @default(true)
  sortOrder           Int     @default(0)
  /// Optional: this step calls out a released Test Procedure
  testProcedureId     String?
  testProcedure       TestProcedure? @relation(fields: [testProcedureId], references: [id], onDelete: SetNull)

  signOffs            WorkInstructionSignOff[]
  woStepCompletions   WorkOrderStepCompletion[]

  @@index([stepType])
}

model WorkInstructionSignOff {
  id          String   @id @default(cuid())
  stepId      String?
  step        WorkInstructionStep? @relation(fields: [stepId], references: [id])
  workInstructionId String
  workInstruction WorkInstruction @relation(fields: [workInstructionId], references: [id])
  workOrderId String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  result      String?  // PASS, FAIL, NA
  measuredValue String?
  measureUom    String?
  notes       String?
  pinVerified Boolean  @default(false)
  signedAt    DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
// WORK ORDERS
// ═══════════════════════════════════════════════════════════════

model WorkOrder {
  id              String   @id @default(cuid())
  number          String   @unique
  // Number prefix by origin: SWO- (sales), BWO- (BOM), MWO- (material requisition), WO- (other)
  type            String   @default("PRODUCTION") // PRODUCTION, TASK_ONLY, REWORK, INSPECTION, PROTOTYPE
  // Origin of the WO — drives numbering and which refs show on traveler
  // SALES_ORDER | BOM | MATERIAL_REQ | OTHER
  sourceType      String   @default("OTHER")
  // BACKLOG → PLANNED → WAITING_MATERIAL → READY_TO_KIT → KITTING → KITTED → RELEASED → IN_PROGRESS → COMPLETED
  status          String   @default("PLANNED")
  priority        String   @default("NORMAL") // LOW, NORMAL, HIGH, CRITICAL
  /// Set when this WO was spawned by an MRB disposition (rework / repair)
  mrbCaseId       String?
  mrbCase         MrbCase? @relation(fields: [mrbCaseId], references: [id], onDelete: SetNull)
  partId          String?
  part            Part?    @relation(fields: [partId], references: [id])
  bomHeaderId     String?
  bomHeader       BomHeader? @relation(fields: [bomHeaderId], references: [id])
  quantity        Float    @default(1)
  quantityCompleted Float  @default(0)
  // Project only when truly project work — not for pure sales-order builds
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id])
  wbsElementId    String?
  wbsElement      WbsElement? @relation(fields: [wbsElementId], references: [id])
  salesOrderId    String?
  salesOrder      SalesOrder? @relation(fields: [salesOrderId], references: [id])
  salesOrderLineId String?
  salesOrderLine  SalesOrderLine? @relation(fields: [salesOrderLineId], references: [id])
  salesOrderRef   String?  // free-text ref kept for legacy seed
  // Forecast-driven material requisition (MWO- prefix)
  materialRequisitionId String?
  materialRequisition   MaterialRequisition? @relation(fields: [materialRequisitionId], references: [id])
  // Leadership business priority alignment (null = Unrated)
  businessPriorityId String?
  businessPriority   BusinessPriority? @relation(fields: [businessPriorityId], references: [id], onDelete: SetNull)
  workCenter      String?
  department      String?
  assigneeId      String?
  assignee        User?    @relation("WOAssignee", fields: [assigneeId], references: [id])
  createdById     String?
  createdBy       User?    @relation("WOCreator", fields: [createdById], references: [id])
  dueDate         DateTime? // customer / planning due date
  plannedStart    DateTime?
  plannedEnd      DateTime?
  actualStart     DateTime?
  actualEnd       DateTime?
  estimatedMinutes Int?
  kitStatus       String   @default("NOT_STARTED") // NOT_STARTED, WAITING_MATERIAL, READY_TO_KIT, KITTING, KITTED
  standardCost    Float    @default(0)
  actualCost      Float    @default(0)
  description     String?
  notes           String?
  travelerNotes   String?  // digital traveler header notes
  requiresInspection Boolean @default(false)
  /// Absolute URL payload used in printed QR (phase-2 mobile deep link)
  qrPayload       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  instructions    WorkOrderInstruction[]
  stepCompletions WorkOrderStepCompletion[]
  materialIssues  MaterialTransaction[]
  timeEntries     TimeEntry[]
  ncrs            NonConformance[]
  inspections     Inspection[]
  statusHistory   WorkOrderStatusHistory[]
  kitOrders       KitOrder[]
  purchaseRequests PurchaseRequest[]
  traceEvents     TraceEvent[]
  mrsLines        MaterialRequisitionLine[]
  productionEngIssues ProductionEngIssue[]
  gfpConsumptions GfpConsumption[]
  assets          Asset[]

  @@index([status])
  @@index([workCenter])
  @@index([projectId])
  @@index([salesOrderId])
  @@index([materialRequisitionId])
  @@index([sourceType])
  @@index([dueDate])
  @@index([businessPriorityId])
}

// ═══════════════════════════════════════════════════════════════
// FORECAST / MATERIAL REQUISITION (build-to-forecast planning)
// ═══════════════════════════════════════════════════════════════

model Forecast {
  id          String   @id @default(cuid())
  number      String   @unique // FC-00001
  name        String
  // DRAFT | ACTIVE | CLOSED | CANCELLED
  status      String   @default("DRAFT")
  periodStart DateTime?
  periodEnd   DateTime?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines                 ForecastLine[]
  materialRequisitions  MaterialRequisition[]

  @@index([status])
}

model ForecastLine {
  id          String   @id @default(cuid())
  forecastId  String
  forecast    Forecast @relation(fields: [forecastId], references: [id], onDelete: Cascade)
  partId      String
  part        Part     @relation(fields: [partId], references: [id])
  quantity    Float    @default(1)
  dueDate     DateTime?
  notes       String?

  @@index([forecastId])
  @@index([partId])
}

// Generated from forecast + stock netting; drives BUILD (MWO) and BUY suggestions
model MaterialRequisition {
  id          String   @id @default(cuid())
  number      String   @unique // MRS-00001
  // DRAFT | RELEASED | IN_PROGRESS | CLOSED | CANCELLED
  status      String   @default("DRAFT")
  forecastId  String?
  forecast    Forecast? @relation(fields: [forecastId], references: [id])
  name        String?
  notes       String?
  createdById String?
  releasedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines       MaterialRequisitionLine[]
  workOrders  WorkOrder[]

  @@index([status])
  @@index([forecastId])
}

model MaterialRequisitionLine {
  id                      String @id @default(cuid())
  materialRequisitionId   String
  materialRequisition     MaterialRequisition @relation(fields: [materialRequisitionId], references: [id], onDelete: Cascade)
  partId                  String
  part                    Part   @relation(fields: [partId], references: [id])
  // Demand after netting (what we still need)
  requiredQty             Float  @default(0)
  // Snapshot of available stock at generation
  onHandQty               Float  @default(0)
  shortQty                Float  @default(0)
  // BUILD = make via MWO | BUY = purchase | STOCK = covered by on-hand | NONE
  action                  String @default("NONE")
  // Parent FG line that drove this component demand (for BOM explosion)
  parentPartId            String?
  workOrderId             String?
  workOrder               WorkOrder? @relation(fields: [workOrderId], references: [id])
  notes                   String?

  @@index([materialRequisitionId])
  @@index([partId])
  @@index([workOrderId])
}

model WorkOrderInstruction {
  id                  String @id @default(cuid())
  workOrderId         String
  workOrder           WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  workInstructionId   String
  workInstruction     WorkInstruction @relation(fields: [workInstructionId], references: [id])
  sequence            Int    @default(1)
}

model WorkOrderStepCompletion {
  id          String   @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  stepId      String
  step        WorkInstructionStep @relation(fields: [stepId], references: [id])
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, PASSED, FAILED, SKIPPED, SIGNED
  result      String?
  measuredValue String?
  // Runtime station assignment (coordinator may change unless step.routeLock)
  assignedWorkCenter String?
  signedById  String?
  signedAt    DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workOrderId, stepId])
  @@index([assignedWorkCenter])
}

model WorkOrderStatusHistory {
  id          String   @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  fromStatus  String?
  toStatus    String
  userId      String?
  notes       String?
  createdAt   DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
// CONFIGURATION MANAGEMENT
// ═══════════════════════════════════════════════════════════════

model ChangeRequest {
  id              String   @id @default(cuid())
  number          String   @unique
  title           String
  description     String
  type            String   // BOM, WORK_INSTRUCTION, DRAWING, SPEC, PROCEDURE, PROCESS, OTHER
  status          String   @default("DRAFT") // DRAFT, SUBMITTED, IMPACT_ANALYSIS, REVIEW_BOARD, APPROVED, REJECTED, IMPLEMENTED, CLOSED
  priority        String   @default("NORMAL")
  requestedById   String?
  impactAnalysis  String?
  affectedParts   String?  // JSON
  bomHeaderId     String?
  bomHeader       BomHeader? @relation(fields: [bomHeaderId], references: [id])
  workInstructionId String?
  workInstruction WorkInstruction? @relation(fields: [workInstructionId], references: [id])
  engineeringTicketId String?
  // ── Document ECR (drawing / policy) fields ──
  // Product the creator targets (product root folder id) or Admin folder id
  productFolderId String?
  productFolder   CmFolder? @relation("CrProductFolder", fields: [productFolderId], references: [id])
  // Free-text product name (required so creator always knows destination)
  productName     String?
  // true = company internal / policy → Admin
  isCompanyInternal Boolean @default(false)
  // Updating existing library doc?
  isDocumentUpdate Boolean @default(false)
  // Source CM document being revised (copy-from)
  sourceDocumentId String?
  sourceDocument   CmDocument? @relation("CrSourceDoc", fields: [sourceDocumentId], references: [id])
  // Working copy fields on the ticket
  documentNumber  String?
  documentTitle   String?
  documentRevision String?
  documentDocType String?  // DRAWING, SPEC, PROCEDURE, FORM, FAT, ATP, TP, TR, etc.
  // Primary file released into the library (drawing PDF, form, etc.)
  documentFileUrl String?
  documentFileName String?
  documentDescription String?
  // Extra attachments carried with the ECR through review (JSON array):
  // [{ id, url, fileName, caption?, uploadedAt, uploadedById?, isPrimary? }]
  documentAttachments String?
  // CM manager sets on release — where released doc lands
  releaseFolderId String?
  releaseFolder   CmFolder? @relation("CrReleaseFolder", fields: [releaseFolderId], references: [id])
  // Resulting library document after release
  releasedDocumentId String?
  releasedDocument   CmDocument? @relation("CrReleasedDoc", fields: [releasedDocumentId], references: [id])
  // Approvers assigned by CM manager (also mirrored in boardMembers)
  approversAssignedAt DateTime?
  boardDate       DateTime?
  decidedAt       DateTime?
  decisionNotes   String?
  releasedAt      DateTime?
  releasedById    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  boardMembers    CmBoardMember[]
  comments        ChangeRequestComment[]

  @@index([status])
  @@index([type])
  @@index([productFolderId])
  @@index([documentNumber])
}

// Discussion / notes on an ECR as it flows through CM review
model ChangeRequestComment {
  id              String   @id @default(cuid())
  changeRequestId String
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  userId          String?
  // Optional display name snapshot (demo auth may not join User)
  authorName      String?
  body            String
  createdAt       DateTime @default(now())

  @@index([changeRequestId])
  @@index([createdAt])
}

model CmBoardMember {
  id              String @id @default(cuid())
  changeRequestId String
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  userId          String
  role            String // CHAIR, ENGINEERING, QUALITY, PRODUCTION, PURCHASING
  vote            String? // APPROVE, REJECT, ABSTAIN
  comments        String?
  votedAt         DateTime?
}

// User-organized CM library — primarily by product; Admin for company policies
model CmFolder {
  id          String   @id @default(cuid())
  name        String
  parentId    String?
  parent      CmFolder?  @relation("CmFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    CmFolder[] @relation("CmFolderTree")
  // PRODUCT = product family root (or child under a product)
  // ADMIN = company internal docs / policies (system-protected root)
  // ARCHIVE = holds locked superseded revisions (under product or Admin)
  kind        String   @default("PRODUCT") // PRODUCT | ADMIN | ARCHIVE
  // Product name when this is a product root (kind=PRODUCT, parentId=null)
  productName String?
  // Optional legacy project link (not used for primary organization)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  productTag  String?  // free-text alias / SKU family
  description String?
  // System folders (e.g. Admin, Archive) cannot be deleted
  isSystem    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents   CmDocument[]
  ecrProducts ChangeRequest[] @relation("CrProductFolder")
  ecrReleases ChangeRequest[] @relation("CrReleaseFolder")
  // Link to PLM product master (when this is a product root folder)
  product     Product?

  @@index([parentId])
  @@index([kind])
  @@index([productName])
  @@index([projectId])
  @@index([sortOrder])
}

model CmDocument {
  id              String   @id @default(cuid())
  folderId        String?
  folder          CmFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  // DRAWING | SPEC | PROCEDURE | WI | BOM | CERT | OTHER
  docType         String   @default("DRAWING")
  number          String
  title           String
  revision        String   @default("A")
  // DRAFT | IN_WORK | RELEASED | OBSOLETE | ARCHIVED
  status          String   @default("IN_WORK")
  description     String?
  // File / link (path, URL, or data URL)
  fileUrl         String?
  fileName        String?
  productTag      String?
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id])
  partId          String?
  part            Part?    @relation(fields: [partId], references: [id])
  workInstructionId String?
  workInstruction WorkInstruction? @relation(fields: [workInstructionId], references: [id])
  bomHeaderId     String?
  bomHeader       BomHeader? @relation(fields: [bomHeaderId], references: [id])
  // Revision chain — locked previous revs live in Archive
  isLocked        Boolean  @default(false)
  isArchived      Boolean  @default(false)
  lockedAt        DateTime?
  supersedesId    String?
  supersedes      CmDocument?  @relation("CmDocRevision", fields: [supersedesId], references: [id])
  supersededBy    CmDocument[] @relation("CmDocRevision")
  sortOrder       Int      @default(0)
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sourceForEcrs   ChangeRequest[] @relation("CrSourceDoc")
  releasedFromEcrs ChangeRequest[] @relation("CrReleasedDoc")
  numberRegistry  CmNumberRegistry? @relation("RegistryReleasedDoc")

  @@index([folderId])
  @@index([docType])
  @@index([status])
  @@index([projectId])
  @@index([number, revision])
  @@index([isArchived])
}

// ═══════════════════════════════════════════════════════════════
// CM NUMBER CONTROL — schemes, requests, master registry
// ═══════════════════════════════════════════════════════════════

/// Customer-configurable number scheme (prefix / format / sequence).
/// Example: DRAWING → DWG-####, PART → PN-#####, POLICY → POL-###
model CmNumberScheme {
  id            String   @id @default(cuid())
  /// Stable code: PART | DRAWING | POLICY | FORM | TEST | SPEC | PROCEDURE | WI | OTHER
  code          String   @unique
  name          String
  description   String?
  /// PART | DOCUMENT | BOTH — what this scheme issues
  appliesTo     String   @default("DOCUMENT")
  prefix        String
  separator     String   @default("-")
  /// Zero-pad width for the numeric sequence (e.g. 4 → 0001)
  padLength     Int      @default(4)
  /// Optional static suffix after sequence (e.g. product family code)
  suffix        String?
  /// Next sequence value to issue (incremented on assign)
  nextSequence  Int      @default(1)
  /// Example preview shown to users, e.g. DWG-0001
  example       String?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requests      CmNumberRequest[]
  registry      CmNumberRegistry[]

  @@index([appliesTo])
  @@index([isActive])
  @@index([sortOrder])
}

/// User request for a new part number or document number.
/// CM manager assigns the number → it lands on the master registry.
model CmNumberRequest {
  id              String   @id @default(cuid())
  /// Human-readable request id, e.g. NREQ-00001
  requestNumber   String   @unique
  /// PENDING | ASSIGNED | REJECTED | CANCELLED
  status          String   @default("PENDING")
  /// Same codes as scheme: PART | DRAWING | POLICY | FORM | TEST | SPEC | PROCEDURE | WI | OTHER
  category        String
  schemeId        String?
  scheme          CmNumberScheme? @relation(fields: [schemeId], references: [id], onDelete: SetNull)
  /// What the number is for (drawing title, policy name, part description…)
  title           String
  description     String?
  justification   String?
  /// Optional preferred number (CM may override)
  preferredNumber String?
  productName     String?
  productFolderId String?
  /// Snapshot of assigned number when CM approves
  assignedNumber  String?
  assignedAt      DateTime?
  assignedById    String?
  cmNotes         String?
  rejectedReason  String?
  requestedById   String?
  requestedByName String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  registryEntry   CmNumberRegistry?

  @@index([status])
  @@index([category])
  @@index([schemeId])
  @@index([requestedById])
  @@index([assignedNumber])
  @@index([createdAt])
}

/// Master CM list of all part numbers and document numbers ever assigned.
model CmNumberRegistry {
  id              String   @id @default(cuid())
  /// Unique controlled number (e.g. DWG-0042, PN-10001, POL-003)
  number          String   @unique
  /// PART | DRAWING | POLICY | FORM | TEST | SPEC | PROCEDURE | WI | OTHER
  category        String
  schemeId        String?
  scheme          CmNumberScheme? @relation(fields: [schemeId], references: [id], onDelete: SetNull)
  title           String
  description     String?
  /// RESERVED (assigned, not yet used) | ACTIVE (ECR/part filed) | RELEASED | OBSOLETE
  status          String   @default("RESERVED")
  productName     String?
  sequenceValue   Int?
  requestId       String?  @unique
  request         CmNumberRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  requestedById   String?
  assignedById    String?
  assignedAt      DateTime @default(now())
  /// Optional link once a part master uses this number
  partId          String?
  /// Optional link once a CM library document is released with this number
  cmDocumentId    String?  @unique
  cmDocument      CmDocument? @relation("RegistryReleasedDoc", fields: [cmDocumentId], references: [id], onDelete: SetNull)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@index([schemeId])
  @@index([partId])
  @@index([assignedAt])
}

// ═══════════════════════════════════════════════════════════════
// PRODUCTS (PLM) — product master, lifecycle, structure, docs
// ═══════════════════════════════════════════════════════════════

/// PLM product master — identity, lifecycle, compliance, structure.
model Product {
  id              String   @id @default(cuid())
  /// Unique product code, e.g. PRD-CM-1000
  code            String   @unique
  name            String
  /// Short summary
  description     String?
  /// Longer “what it is” narrative for PLM / design history
  overview        String?
  /// Platform / family grouping
  productFamily   String?
  productLine     String?
  modelNumber     String?
  revision        String   @default("A")

  /// CONCEPT | DESIGN | DEVELOPMENT | QUALIFICATION | PRODUCTION | SUSTAINMENT | EOL | OBSOLETE
  lifecyclePhase  String   @default("CONCEPT")
  phaseEnteredAt  DateTime @default(now())
  /// ACTIVE | ON_HOLD | CANCELLED | OBSOLETE
  status          String   @default("ACTIVE")

  // Market / customer
  marketSegment   String?
  customerName    String?
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])

  // Ownership
  productOwnerId    String?
  productOwner      User?   @relation("ProductOwner", fields: [productOwnerId], references: [id])
  engineeringLeadId String?
  engineeringLead   User?   @relation("ProductEngLead", fields: [engineeringLeadId], references: [id])
  cmOwnerId         String?
  cmOwner           User?   @relation("ProductCmOwner", fields: [cmOwnerId], references: [id])

  // Top-level assembly (primary finished good / TLA)
  topLevelPartId  String?
  topLevelPart    Part?    @relation("ProductTopLevelPart", fields: [topLevelPartId], references: [id])

  // Linked CM library product root folder
  cmFolderId      String?  @unique
  cmFolder        CmFolder? @relation(fields: [cmFolderId], references: [id], onDelete: SetNull)

  // Technical / commercial targets
  targetCost      Float?
  standardCost    Float?
  estimatedWeight Float?
  weightUom       String?  @default("LB")
  targetLeadDays  Int?

  // Compliance / export / quality
  itarControlled  Boolean  @default(false)
  exportControl   String?  // NONE | EAR | ITAR | OTHER
  qualityStandard String?  // AS9100, ISO9001, …
  nsn             String?  // National stock number
  cageCode        String?
  regulatoryNotes String?

  // Key lifecycle dates
  conceptDate              DateTime?
  designStartDate          DateTime?
  developmentStartDate     DateTime?
  qualificationStartDate   DateTime?
  firstArticleDate         DateTime?
  productionReleaseDate    DateTime?
  sustainmentStartDate     DateTime?
  eolDate                  DateTime?
  obsoleteDate             DateTime?

  notes           String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lifecycleEvents ProductLifecycleEvent[]
  members         ProductMember[]
  partLinks       ProductPart[]
  documentLinks   ProductDocument[]
  variants        ProductVariant[]
  requirements    ProductRequirement[]
  milestones      ProductMilestone[]
  // PMO links — development programs/projects that build this product
  projectLinks    ProjectProduct[]
  primaryProjects Project[]          @relation("ProjectPrimaryProduct")
  costEntries     ProjectCostEntry[]
  /// Rolled-up NRE / development cost captured from linked projects
  developmentBudget Float @default(0)
  developmentActual Float @default(0)
  /// Sustainment / product-linked eng tasks (outside or inside projects)
  engTasks        EngTask[]
  productionIssues ProductionEngIssue[]
  virtualAssets   VirtualAsset[]

  @@index([lifecyclePhase])
  @@index([status])
  @@index([productFamily])
  @@index([customerId])
  @@index([topLevelPartId])
  @@index([name])
}

model ProductLifecycleEvent {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromPhase   String?
  toPhase     String
  notes       String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

model ProductMember {
  id          String  @id @default(cuid())
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// OWNER | ENG_LEAD | CM | QUALITY | MANUFACTURING | SUPPLY_CHAIN | OTHER
  role        String  @default("OTHER")
  notes       String?

  @@unique([productId, userId, role])
  @@index([productId])
  @@index([userId])
}

/// Parts structured against the product (TLA, major assemblies, options, spares).
model ProductPart {
  id          String  @id @default(cuid())
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  partId      String
  part        Part    @relation(fields: [partId], references: [id], onDelete: Cascade)
  /// TOP_LEVEL | MAJOR_ASSEMBLY | OPTION | SPARE | RELATED | TOOLING
  role        String  @default("RELATED")
  notes       String?
  sortOrder   Int     @default(0)

  @@unique([productId, partId, role])
  @@index([productId])
  @@index([partId])
}

/// Controlled or reference documents on the product (CM library and/or free refs).
model ProductDocument {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  cmDocumentId  String?
  /// DRAWING | SPEC | PROCEDURE | WI | BOM | MANUAL | CERT | OTHER
  docType       String   @default("OTHER")
  number        String?
  title         String
  revision      String?
  status        String?  // mirrors CM when linked
  url           String?
  notes         String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([cmDocumentId])
  @@index([docType])
}

model ProductVariant {
  id              String  @id @default(cuid())
  productId       String
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  code            String
  name            String
  description     String?
  isDefault       Boolean @default(false)
  isActive        Boolean @default(true)
  topLevelPartId  String?
  topLevelPart    Part?   @relation(fields: [topLevelPartId], references: [id])
  sortOrder       Int     @default(0)

  @@unique([productId, code])
  @@index([productId])
}

/// Product requirements / design inputs (lightweight PLM requirements list).
model ProductRequirement {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  number      String
  title       String
  description String?
  /// FUNCTIONAL | PERFORMANCE | SAFETY | REGULATORY | INTERFACE | ENVIRONMENTAL | OTHER
  category    String   @default("FUNCTIONAL")
  /// DRAFT | APPROVED | VERIFIED | WAIVED | OBSOLETE
  status      String   @default("DRAFT")
  priority    String   @default("NORMAL") // LOW | NORMAL | HIGH | CRITICAL
  source      String?  // customer SOW, standard, internal
  verificationMethod String? // TEST | ANALYSIS | INSPECTION | DEMONSTRATION
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, number])
  @@index([productId])
  @@index([status])
  @@index([category])
}

model ProductMilestone {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String
  /// GATE | REVIEW | RELEASE | OTHER
  kind        String    @default("GATE")
  targetDate  DateTime?
  actualDate  DateTime?
  /// PLANNED | IN_PROGRESS | COMPLETE | MISSED | CANCELLED
  status      String    @default("PLANNED")
  notes       String?
  sortOrder   Int       @default(0)

  @@index([productId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════
// PMO — Programs, Projects, EVM, agile/waterfall, product links
// ═══════════════════════════════════════════════════════════════

/// Portfolio / program that groups projects (PMO hierarchy).
model Program {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  description     String?
  /// ACTIVE | ON_HOLD | COMPLETED | CANCELLED
  status          String   @default("ACTIVE")
  /// Free-text portfolio grouping (e.g. Defense, Commercial)
  portfolio       String?
  ownerId         String?
  owner           User?    @relation("ProgramOwner", fields: [ownerId], references: [id])
  budgetCost      Float    @default(0)
  actualCost      Float    @default(0)
  startDate       DateTime?
  endDate         DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projects        Project[]
  virtualAssets   VirtualAsset[]

  @@index([status])
  @@index([portfolio])
}

model Project {
  id              String   @id @default(cuid())
  number          String   @unique
  name            String
  description     String?
  /// PLANNING | ACTIVE | ON_HOLD | COMPLETED | CANCELLED
  status          String   @default("PLANNING")
  /// WATERFALL | AGILE | HYBRID
  methodology     String   @default("HYBRID")
  /// INITIATION | PLANNING | EXECUTION | MONITORING | CLOSURE (waterfall) or ongoing for agile
  phase           String   @default("INITIATION")
  customerName    String?
  contractValue   Float    @default(0)
  budgetCost      Float    @default(0)
  actualCost      Float    @default(0)
  plannedValue    Float    @default(0) // PV / BCWS
  earnedValue     Float    @default(0) // EV / BCWP
  /// NRE / product development cost tracked on this project
  developmentBudget Float  @default(0)
  developmentActual Float  @default(0)
  startDate       DateTime?
  endDate         DateTime?
  percentComplete Float    @default(0)

  // PMO hierarchy
  programId       String?
  program         Program? @relation(fields: [programId], references: [id], onDelete: SetNull)

  // Primary product this project develops / delivers
  productId       String?
  product         Product? @relation("ProjectPrimaryProduct", fields: [productId], references: [id], onDelete: SetNull)

  // Charter / setup
  /// DRAFT | APPROVED | SUPERSEDED
  charterStatus   String   @default("DRAFT")
  businessCase    String?
  objectives      String?
  scopeIn         String?
  scopeOut        String?
  successCriteria String?
  assumptions     String?
  constraints     String?
  deliverables    String?
  stakeholdersSummary String?
  sponsorId       String?
  sponsor         User?    @relation("ProjectSponsor", fields: [sponsorId], references: [id])
  projectManagerId String?
  projectManager  User?    @relation("ProjectManager", fields: [projectManagerId], references: [id])
  charterApprovedAt DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  wbsElements     WbsElement[]
  tasks           ProjectTask[]
  milestones      Milestone[]
  risks           ProjectRisk[]
  issues          ProjectIssue[]
  workOrders      WorkOrder[]
  purchaseOrders  PurchaseOrder[]
  purchaseRequests PurchaseRequest[]
  members         ProjectMember[]
  timeEntries     TimeEntry[]
  cmFolders       CmFolder[]
  cmDocuments     CmDocument[]
  productLinks    ProjectProduct[]
  requirements    ProjectRequirement[]
  raciEntries     ProjectRaciEntry[]
  communications  ProjectCommunication[]
  wikiPages       ProjectWikiPage[]
  piIncrements    PiIncrement[]
  costEntries     ProjectCostEntry[]
  campaigns       Campaign[]
  sagas           Saga[]
  virtualAssets   VirtualAsset[]
  engTasks        EngTask[]
  productionIssues ProductionEngIssue[]

  @@index([programId])
  @@index([productId])
  @@index([status])
  @@index([methodology])
  @@index([phase])
}

/// Many-to-many: projects can touch multiple products; products can have multiple projects.
model ProjectProduct {
  id          String  @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// PRIMARY | ENABLING | DERIVATIVE | SUSTAINMENT
  role        String  @default("PRIMARY")
  /// When true, pushing reqs/milestones/cost to product is allowed
  syncRequirements Boolean @default(true)
  syncMilestones   Boolean @default(true)
  syncCosts        Boolean @default(true)
  notes       String?

  @@unique([projectId, productId])
  @@index([productId])
}

/// Project-level requirements — can be pushed into ProductRequirement on the linked product.
model ProjectRequirement {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number      String
  title       String
  description String?
  category    String   @default("FUNCTIONAL")
  status      String   @default("DRAFT")
  priority    String   @default("NORMAL")
  source      String?
  verificationMethod String?
  /// Set when synced to product master
  productRequirementId String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, number])
  @@index([projectId])
  @@index([status])
}

/// Hierarchical WBS — PMBOK deliverable-oriented decomposition (100% rule).
/// Click an element for full detail; expand children as line items.
model WbsElement {
  id              String  @id @default(cuid())
  projectId       String
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code            String
  name            String
  /// SUMMARY | CONTROL_ACCOUNT | WORK_PACKAGE | PLANNING_PACKAGE
  kind            String  @default("WORK_PACKAGE")
  description     String?
  /// Deliverables / SOW language for this node
  deliverables    String?
  acceptanceCriteria String?
  assumptions     String?
  constraints     String?
  resources       String?  // skillsets, orgs, equipment
  notes           String?
  /// NOT_STARTED | IN_PROGRESS | COMPLETE | ON_HOLD
  status          String  @default("NOT_STARTED")
  parentId        String?
  parent          WbsElement?  @relation("WbsTree", fields: [parentId], references: [id], onDelete: Cascade)
  children        WbsElement[] @relation("WbsTree")
  ownerId         String?
  startDate       DateTime?
  endDate         DateTime?
  budgetCost      Float   @default(0)
  actualCost      Float   @default(0)
  percentComplete Float   @default(0)
  sortOrder       Int     @default(0)
  /// Depth hint: 0 = root under project, 1 = major, 2+ = sub
  level           Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workOrders      WorkOrder[]
  purchaseOrders  PurchaseOrder[]
  tasks           ProjectTask[]
  campaigns       Campaign[]

  @@index([projectId])
  @@index([parentId])
  @@index([code])
  @@index([kind])
  timeEntries     TimeEntry[]

}

// ── Campaign → Saga → Task (Jira-like, PMO + Engineering) ─────

/// PM-owned campaign: body of work supporting a WBS element / project objective.
model Campaign {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbsElementId    String?
  wbsElement      WbsElement? @relation(fields: [wbsElementId], references: [id], onDelete: SetNull)
  number          String
  name            String
  description     String?
  /// Definition of Done for the campaign (PM + eng agreed)
  definitionOfDone String?
  /// BACKLOG | PLANNED | IN_PROGRESS | BLOCKED | DONE | CANCELLED
  status          String   @default("PLANNED")
  priority        String   @default("NORMAL")
  ownerId         String?  // PM owner
  // Leadership business priority alignment (null = Unrated)
  businessPriorityId String?
  businessPriority   BusinessPriority? @relation(fields: [businessPriorityId], references: [id], onDelete: SetNull)
  startDate       DateTime?
  endDate         DateTime?
  dueDate         DateTime?
  estimatedHours  Float    @default(0)
  actualHours     Float    @default(0)
  storyPoints     Float    @default(0)
  percentComplete Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sagas           Saga[]
  engTasks        EngTask[]
  timeEntries     TimeEntry[]

  @@unique([projectId, number])
  @@index([projectId])
  @@index([wbsElementId])
  @@index([status])
  @@index([businessPriorityId])
}

/// Engineering saga under a campaign — owned by a discipline swim lane.
model Saga {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  number          String
  name            String
  description     String?
  /// SYSTEMS | MECHANICAL | ELECTRICAL | NETWORK | CYBER | SOFTWARE | HARDWARE | RF | QUALITY | OTHER
  discipline      String   @default("SYSTEMS")
  definitionOfDone String?
  /// BACKLOG | TODO | IN_PROGRESS | IN_REVIEW | BLOCKED | DONE | CANCELLED
  status          String   @default("BACKLOG")
  priority        String   @default("NORMAL")
  ownerId         String?  // eng lead for this saga
  // Leadership business priority alignment (null = Unrated)
  businessPriorityId String?
  businessPriority   BusinessPriority? @relation(fields: [businessPriorityId], references: [id], onDelete: SetNull)
  startDate       DateTime?
  endDate         DateTime?
  dueDate         DateTime?
  estimatedHours  Float    @default(0)
  actualHours     Float    @default(0)
  storyPoints     Float    @default(0)
  percentComplete Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  engSprintId     String?
  engSprint       EngSprint? @relation(fields: [engSprintId], references: [id], onDelete: SetNull)
  engTasks        EngTask[]
  timeEntries     TimeEntry[]
  // Cross-lane dependencies
  blockedBy       EngDependency[] @relation("DepTargetSaga")
  blocking        EngDependency[] @relation("DepSourceSaga")

  @@unique([campaignId, number])
  @@index([projectId])
  @@index([campaignId])
  @@index([discipline])
  @@index([status])
  @@index([engSprintId])
  @@index([businessPriorityId])
}

/// Engineering task / subtask under a saga (or loose under campaign / product).
/// projectId optional — sustainment work can be product-only (no open project).
model EngTask {
  id              String   @id @default(cuid())
  projectId       String?
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  /// Product master link — sustainment BOM/doc updates outside a project
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  campaignId      String?
  campaign        Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  sagaId          String?
  saga            Saga?     @relation(fields: [sagaId], references: [id], onDelete: Cascade)
  parentId        String?
  parent          EngTask?  @relation("EngTaskTree", fields: [parentId], references: [id], onDelete: Cascade)
  children        EngTask[] @relation("EngTaskTree")
  engSprintId     String?
  engSprint       EngSprint? @relation(fields: [engSprintId], references: [id], onDelete: SetNull)
  number          String   @unique
  name            String
  description     String?
  /// TASK | SUBTASK | SPIKE | BUG | SUSTAINMENT | PROD_SUPPORT
  kind            String   @default("TASK")
  discipline      String?  // inherits saga if null; MFG_ENG for manufacturing engineering
  /// BACKLOG | TODO | IN_PROGRESS | IN_REVIEW | BLOCKED | DONE | CANCELLED
  status          String   @default("TODO")
  priority        String   @default("NORMAL")
  assigneeId      String?
  // Leadership business priority alignment (null = Unrated)
  businessPriorityId String?
  businessPriority   BusinessPriority? @relation(fields: [businessPriorityId], references: [id], onDelete: SetNull)
  startDate       DateTime?
  endDate         DateTime?
  dueDate         DateTime?
  estimatedHours  Float    @default(0)
  actualHours     Float    @default(0)
  storyPoints     Float?
  percentComplete Float    @default(0)
  /// Open scan-in session (engineer currently clocked on this task)
  activeScanUserId String?
  activeScanAt    DateTime?
  /// Production support ticket that spawned this task (if any)
  productionIssueId String? @unique
  productionIssue ProductionEngIssue? @relation(fields: [productionIssueId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  timeEntries     TimeEntry[]
  scans           WorkTimeScan[]
  blockedBy       EngDependency[] @relation("DepTargetTask")
  blocking        EngDependency[] @relation("DepSourceTask")
  assets          Asset[]

  @@index([projectId])
  @@index([productId])
  @@index([campaignId])
  @@index([sagaId])
  @@index([parentId])
  @@index([status])
  @@index([assigneeId])
  @@index([discipline])
  @@index([engSprintId])
  @@index([kind])
  @@index([businessPriorityId])
}

/// Production → Manufacturing Engineering support ticket.
/// Floor/production raises issues (hardware, process, docs); ME board picks them up,
/// can clarify, fix process, or open an ECR.
model ProductionEngIssue {
  id              String   @id @default(cuid())
  number          String   @unique
  title           String
  description     String?
  /// HARDWARE | PROCESS | DOCUMENT | BOM | TOOLING | OTHER
  category        String   @default("PROCESS")
  /// OPEN | TRIAGED | IN_PROGRESS | WAITING_ECR | RESOLVED | CLOSED | REJECTED
  status          String   @default("OPEN")
  priority        String   @default("NORMAL") // LOW | NORMAL | HIGH | CRITICAL
  reportedById    String?
  reportedByName  String?
  workOrderId     String?
  workOrder       WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  partId          String?
  part            Part?      @relation(fields: [partId], references: [id], onDelete: SetNull)
  productId       String?
  product         Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  projectId       String?
  project         Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  /// Where found: STATION | RECEIVING | TEST | INSPECTION | OTHER
  sourceArea      String?
  workCenter      String?
  /// Linked ME task when accepted onto MFG_ENG board
  engTask         EngTask?
  /// ECR opened to fix controlled docs (optional)
  changeRequestId String?
  resolution      String?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([workOrderId])
  @@index([productId])
  @@index([partId])
  @@index([priority])
  @@index([createdAt])
}

/// Cross-swim-lane (and within-lane) dependencies between tasks and/or sagas.
/// source must finish (or be satisfied) before target can proceed.
model EngDependency {
  id              String   @id @default(cuid())
  /// FINISH_TO_START | START_TO_START | FINISH_TO_FINISH | BLOCKS
  type            String   @default("FINISH_TO_START")
  notes           String?
  /// Source (predecessor) — at least one of sourceTaskId / sourceSagaId
  sourceTaskId    String?
  sourceTask      EngTask? @relation("DepSourceTask", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  sourceSagaId    String?
  sourceSaga      Saga?    @relation("DepSourceSaga", fields: [sourceSagaId], references: [id], onDelete: Cascade)
  /// Target (successor)
  targetTaskId    String?
  targetTask      EngTask? @relation("DepTargetTask", fields: [targetTaskId], references: [id], onDelete: Cascade)
  targetSagaId    String?
  targetSaga      Saga?    @relation("DepTargetSaga", fields: [targetSagaId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([sourceTaskId])
  @@index([sourceSagaId])
  @@index([targetTaskId])
  @@index([targetSagaId])
}

/// PMO-defined planning quarter (houses sprints for PI planning).
model PlanningQuarter {
  id          String   @id @default(cuid())
  /// e.g. 2026-Q3
  code        String   @unique
  name        String
  year        Int
  quarter     Int      // 1-4
  startDate   DateTime
  endDate     DateTime
  /// PLANNED | ACTIVE | CLOSED
  status      String   @default("PLANNED")
  goals       String?  // PI / quarter objectives from leadership & PMO
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sprints     EngSprint[]

  @@index([year, quarter])
  @@index([status])
}

/// Discipline-scoped sprint — created by PMO under a quarter; lanes populate work.
model EngSprint {
  id          String    @id @default(cuid())
  name        String
  goal        String?
  /// Optional: limit sprint to one swim lane; null = multi-discipline / all lanes
  discipline  String?
  projectId   String?
  quarterId   String?
  quarter     PlanningQuarter? @relation(fields: [quarterId], references: [id], onDelete: SetNull)
  startDate   DateTime?
  endDate     DateTime?
  /// PLANNED | ACTIVE | COMPLETED
  status      String    @default("PLANNED")
  /// True when created via PMO PI planning (not lane managers)
  createdByPmo Boolean  @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sagas       Saga[]
  engTasks    EngTask[]

  @@index([discipline])
  @@index([projectId])
  @@index([quarterId])
  @@index([status])
}

/// Senior leadership published business priorities (readable by all).
model BusinessPriority {
  id          String   @id @default(cuid())
  number      String   @unique
  title       String
  description String?
  /// STRATEGIC | FINANCIAL | OPERATIONAL | COMPLIANCE | CUSTOMER | PEOPLE
  category    String   @default("STRATEGIC")
  /// DRAFT | PUBLISHED | ARCHIVED
  status      String   @default("DRAFT")
  priority    Int      @default(1) // 1 = highest
  ownerRole   String?  // CEO | CFO | COO | VP_ENG | VP_OPS | etc.
  publishedAt DateTime?
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workOrders  WorkOrder[]
  campaigns   Campaign[]
  sagas       Saga[]
  engTasks    EngTask[]

  @@index([status])
  @@index([priority])
  @@index([category])
}

/// Fine-grained permission catalog.
model Permission {
  id          String   @id @default(cuid())
  /// e.g. engineering.task.create, accounting.journal.post
  code        String   @unique
  name        String
  module      String
  description String?

  groupLinks  PermissionGroupMember[]
  userGrants  UserPermission[]
}

model PermissionGroup {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  /// Optional base ERP role this group extends
  baseRole    String?
  createdAt   DateTime @default(now())

  permissions PermissionGroupMember[]
  users       UserPermissionGroup[]
}

model PermissionGroupMember {
  id           String @id @default(cuid())
  groupId      String
  group        PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([groupId, permissionId])
}

model UserPermissionGroup {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId  String
  group    PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model UserPermission {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  /// true = grant, false = explicit deny
  allowed      Boolean @default(true)

  @@unique([userId, permissionId])
}

/// Configurable engineering swim lanes (create / deactivate).
model EngSwimLane {
  id          String   @id @default(cuid())
  /// Stable code used on Saga/EngTask.discipline (e.g. SOFTWARE, MFG_ENG)
  code        String   @unique
  name        String
  description String?
  color       String?  // tailwind-ish accent key
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  /// System lanes cannot be hard-deleted (only deactivated)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

/// Alerts for PMs when dependencies are created or block work.
model EngAlert {
  id          String   @id @default(cuid())
  /// DEPENDENCY_CREATED | DEPENDENCY_BLOCKING | TASK_BLOCKED
  type        String
  title       String
  body        String?
  projectId   String?
  engTaskId   String?
  sagaId      String?
  dependencyId String?
  /// Unread until PM acknowledges
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([isRead])
  @@index([createdAt])
}

/// Scan-in / scan-out sessions for engineering time on a task.
model WorkTimeScan {
  id          String    @id @default(cuid())
  engTaskId   String
  engTask     EngTask   @relation(fields: [engTaskId], references: [id], onDelete: Cascade)
  userId      String
  scannedInAt DateTime  @default(now())
  scannedOutAt DateTime?
  hours       Float?    // filled on scan-out
  notes       String?
  /// OPEN | CLOSED
  status      String    @default("OPEN")

  @@index([engTaskId])
  @@index([userId])
  @@index([status])
}

/// Legacy project task list (schedule tab) — kept for WBS/PI links.
model ProjectTask {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbsElementId    String?
  wbsElement      WbsElement? @relation(fields: [wbsElementId], references: [id])
  name            String
  description     String?
  status          String    @default("TODO") // TODO, IN_PROGRESS, BLOCKED, DONE
  priority        String    @default("NORMAL")
  /// STORY | TASK | SPIKE | ENABLER | BUG (agile) or generic task
  kind            String    @default("TASK")
  storyPoints     Float?
  sprintLabel     String?   // free-text sprint / iteration name
  piIncrementId   String?
  piIncrement     PiIncrement? @relation(fields: [piIncrementId], references: [id], onDelete: SetNull)
  assigneeId      String?
  startDate       DateTime?
  endDate         DateTime?
  estimatedHours  Float?
  actualHours     Float     @default(0)
  percentComplete Float     @default(0)
  dependsOnIds    String?   // JSON array of task ids
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([piIncrementId])
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  dueDate     DateTime?
  actualDate  DateTime?
  status      String    @default("PENDING") // PENDING, ACHIEVED, MISSED, CANCELLED
  description String?
  /// PDR | CDR | TRR | SRR | FAI | GATE | RELEASE | OTHER — gates that sync to product lifecycle
  kind        String    @default("GATE")
  /// Optional product milestone created/updated from this project gate
  productMilestoneId String?

  @@index([projectId])
  @@index([kind])
}

model ProjectRisk {
  id          String  @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number      String?
  title       String
  description String?
  category    String? // TECHNICAL | SCHEDULE | COST | SUPPLY | QUALITY | OTHER
  probability String  @default("MEDIUM") // LOW, MEDIUM, HIGH
  impact      String  @default("MEDIUM")
  score       Int     @default(0) // computed or manual 1–25
  status      String  @default("OPEN") // OPEN, MITIGATING, ACCEPTED, CLOSED
  mitigation  String?
  contingency String?
  residualRisk String?
  ownerId     String?
  targetDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([status])
}

model ProjectIssue {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number      String?
  title       String
  description String?
  category    String?
  status      String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String    @default("NORMAL")
  ownerId     String?
  resolution  String?
  raisedAt    DateTime  @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
  @@index([status])
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  role      String  @default("MEMBER") // PM, SPONSOR, MEMBER, STAKEHOLDER, TECH_LEAD, SCRUM_MASTER
}

/// RACI matrix rows — one activity with R/A/C/I assignments (names or user ids as text).
model ProjectRaciEntry {
  id          String  @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activity    String
  /// Responsible (does the work)
  responsible String?
  /// Accountable (one owner)
  accountable String?
  /// Consulted
  consulted   String?
  /// Informed
  informed    String?
  sortOrder   Int     @default(0)
  notes       String?

  @@index([projectId])
}

model ProjectCommunication {
  id          String  @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  audience    String
  purpose     String?
  frequency   String? // DAILY | WEEKLY | BIWEEKLY | MONTHLY | AD_HOC | MILESTONE
  channel     String? // MEETING | EMAIL | SLACK | REPORT | WIKI
  ownerName   String?
  notes       String?
  sortOrder   Int     @default(0)

  @@index([projectId])
}

/// Confluence-style project wiki pages (markdown body).
model ProjectWikiPage {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  body        String   @default("")
  parentId    String?
  parent      ProjectWikiPage?  @relation("WikiTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    ProjectWikiPage[] @relation("WikiTree")
  sortOrder   Int      @default(0)
  updatedById String?
  updatedBy   User?    @relation(fields: [updatedById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, slug])
  @@index([projectId])
  @@index([parentId])
}

/// SAFe-style PI (Program Increment) for agile / hybrid projects.
model PiIncrement {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  number      Int       @default(1)
  goals       String?
  startDate   DateTime?
  endDate     DateTime?
  /// PLANNED | ACTIVE | COMPLETE | CANCELLED
  status      String    @default("PLANNED")
  capacityPoints Float?
  committedPoints Float?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  features    PiFeature[]
  tasks       ProjectTask[]

  @@index([projectId])
  @@index([status])
}

model PiFeature {
  id          String  @id @default(cuid())
  piId        String
  pi          PiIncrement @relation(fields: [piId], references: [id], onDelete: Cascade)
  name        String
  description String?
  /// BACKLOG | COMMITTED | IN_PROGRESS | DONE | DEFERRED
  status      String  @default("BACKLOG")
  storyPoints Float?
  ownerName   String?
  sortOrder   Int     @default(0)

  @@index([piId])
}

/// Development / NRE cost lines — roll up to project and optionally product.
model ProjectCostEntry {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  /// LABOR | MATERIAL | NRE | TRAVEL | TOOLING | TEST | OTHER
  category    String   @default("LABOR")
  description String?
  amount      Float    @default(0)
  hours       Float?
  entryDate   DateTime @default(now())
  source      String?  // TIMESHEET | MANUAL | PO | WO
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([productId])
  @@index([category])
  @@index([entryDate])
}

// ═══════════════════════════════════════════════════════════════
// QUALITY / MRB / NCR / INSPECTIONS
// ═══════════════════════════════════════════════════════════════

model Inspection {
  id              String   @id @default(cuid())
  number          String   @unique
  // RECEIVING, VISUAL, GDT, FUNCTIONAL, IN_PROCESS, FINAL
  type            String
  status          String   @default("PENDING") // PENDING, IN_PROGRESS, PASSED, FAILED, WAIVED
  partId          String?
  workOrderId     String?
  workOrder       WorkOrder? @relation(fields: [workOrderId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  receiptId       String?
  inventoryItemId String?
  lotNumber       String?
  serialNumber    String?
  quantity        Float    @default(1)
  quantityPassed  Float    @default(0)
  quantityFailed  Float    @default(0)
  inspectorId     String?
  workCenter      String?  // e.g. TEST-01 when routed to test
  // Planned stock location after all receiving tests pass
  plannedPutawayCode String?
  notes           String?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  results         InspectionResult[]
  ncrs            NonConformance[]
  documents       ReceivingDocument[]

  @@index([status, workCenter])
  @@index([type, status])
  @@index([workOrderId])
}

model InspectionResult {
  id            String  @id @default(cuid())
  inspectionId  String
  inspection    Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  characteristic String
  specification String?
  measuredValue String?
  result        String  // PASS, FAIL, NA
  notes         String?
}

model NonConformance {
  id              String   @id @default(cuid())
  number          String   @unique
  title           String
  description     String
  status          String   @default("OPEN") // OPEN, UNDER_REVIEW, MRB, DISPOSITIONED, CLOSED
  severity        String   @default("MINOR") // MINOR, MAJOR, CRITICAL
  source          String   // RECEIVING, IN_PROCESS, FINAL, CUSTOMER, SUPPLIER
  partId          String?
  part            Part?    @relation(fields: [partId], references: [id])
  workOrderId     String?
  workOrder       WorkOrder? @relation(fields: [workOrderId], references: [id])
  inspectionId    String?
  inspection      Inspection? @relation(fields: [inspectionId], references: [id])
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  quantity        Float    @default(1)
  lotNumber       String?
  serialNumber    String?
  createdById     String?
  createdBy       User?    @relation("NCRCreator", fields: [createdById], references: [id])
  rootCause       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  closedAt        DateTime?

  mrbCases        MrbCase[]
}

model MrbCase {
  id              String   @id @default(cuid())
  number          String   @unique
  ncrId           String
  ncr             NonConformance @relation(fields: [ncrId], references: [id])
  status          String   @default("OPEN") // OPEN, IN_REVIEW, DISPOSITIONED, CLOSED
  boardDate       DateTime?
  chairId         String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  closedAt        DateTime?

  dispositions    MrbDisposition[]
  inventoryHolds  InventoryItem[]
  workOrders      WorkOrder[]
  returnShipments Shipment[]
  replacementPrs  PurchaseRequest[]
}

model MrbDisposition {
  id              String   @id @default(cuid())
  mrbCaseId       String
  mrbCase         MrbCase  @relation(fields: [mrbCaseId], references: [id], onDelete: Cascade)
  disposition     String   // USE_AS_IS, REWORK, SCRAP, RETURN_TO_SUPPLIER, REPAIR
  quantity        Float    @default(1)
  justification   String?
  decidedById     String?
  decidedBy       User?    @relation(fields: [decidedById], references: [id])
  decidedAt       DateTime @default(now())
  // Corrective Action Request (created at disposition when requested)
  carNumber       String?
  carStatus       String?  // OPEN, IN_PROGRESS, RESPONSE_RECEIVED, VERIFIED, CLOSED
  carTitle        String?
  carNotes        String?
  carResponse     String?
  carDueDate      DateTime?
  carClosedAt     DateTime?
  reworkWorkOrderId String? // WO created for REWORK disposition
  repairWorkOrderId String? // WO created for REPAIR disposition
  returnShipmentId  String? // return-to-vendor shipment (RETURN_TO_SUPPLIER)
  replacementPrId   String? // replacement purchase request (SCRAP)
  // Vendor email / acknowledgment attachments (JSON: [{url,fileName,caption}])
  carAttachments  String?

  // Traceability log for CAR lifecycle (create + every update)
  activityLog     CarActivityLog[]
}

// Append-only traceability log for Corrective Action Requests
model CarActivityLog {
  id              String   @id @default(cuid())
  dispositionId   String
  disposition     MrbDisposition @relation(fields: [dispositionId], references: [id], onDelete: Cascade)
  carNumber       String
  // CREATED | STATUS_CHANGE | RESPONSE_UPDATED | NOTES_UPDATED | ATTACHMENT_ADDED | VERIFIED_CLOSED | UPDATED
  action          String
  summary         String
  // JSON: { field: { from, to }, ... } or attachment metadata
  changes         String?
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())

  @@index([dispositionId, createdAt])
  @@index([carNumber])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// INVENTORY
// ═══════════════════════════════════════════════════════════════

model Warehouse {
  id        String @id @default(cuid())
  code      String @unique
  name      String
  isActive  Boolean @default(true)

  locations Location[]
}

model Location {
  id          String @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  code        String
  name        String?
  // STORAGE, RECEIVING, QUARANTINE, SHIPPING, WIP, GFP (gov-furnished property cage / area)
  type        String @default("STORAGE")

  inventoryItems InventoryItem[]

  @@unique([warehouseId, code])
}

model InventoryItem {
  id              String  @id @default(cuid())
  partId          String
  part            Part    @relation(fields: [partId], references: [id])
  locationId      String
  location        Location @relation(fields: [locationId], references: [id])
  quantityOnHand  Float   @default(0)
  quantityAvailable Float @default(0)
  quantityCommitted Float @default(0)
  quantityQuarantine Float @default(0)
  ownership       String  @default("COMPANY") // COMPANY, CUSTOMER, GOVERNMENT
  lotNumber       String?
  serialNumber    String?
  unitCost        Float   @default(0)
  lastCountedAt   DateTime?
  mrbCaseId       String?
  mrbCase         MrbCase? @relation(fields: [mrbCaseId], references: [id])
  updatedAt       DateTime @updatedAt

  transactions    MaterialTransaction[]
  governmentProperty GovernmentProperty?

  @@index([partId])
  @@index([ownership])
}

model MaterialTransaction {
  id              String   @id @default(cuid())
  type            String   // RECEIPT, PUTAWAY, ISSUE, KIT, TRANSFER, ADJUSTMENT, QUARANTINE, RELEASE, SCRAP, SHIP, WO_COMPLETE
  partId          String?
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  workOrderId     String?
  workOrder       WorkOrder? @relation(fields: [workOrderId], references: [id])
  purchaseOrderId String?
  salesOrderId    String?
  kitOrderId      String?
  quantity        Float
  unitCost        Float    @default(0)
  fromLocation    String?
  toLocation      String?
  lotNumber       String?
  serialNumber    String?
  reference       String?
  notes           String?
  photoUrls       String?  // JSON array of photo paths / mock URLs
  userId          String?
  createdAt       DateTime @default(now())

  @@index([type])
  @@index([workOrderId])
  @@index([lotNumber])
}

model Lot {
  id          String   @id @default(cuid())
  lotNumber   String   @unique
  partId      String
  part        Part     @relation(fields: [partId], references: [id])
  quantity    Float
  receivedAt  DateTime?
  supplierId  String?
  poNumber    String?
  expiresAt   DateTime?
  status      String   @default("AVAILABLE")
}

model SerialNumber {
  id          String  @id @default(cuid())
  serial      String  @unique
  partId      String
  part        Part    @relation(fields: [partId], references: [id])
  status      String  @default("IN_STOCK") // IN_STOCK, ISSUED, INSTALLED, SHIPPED, QUARANTINE, SCRAPPED
  workOrderId String?
  lotNumber   String?
  uid         String? // DoD Unique Item Identifier
  ownership   String  @default("COMPANY")
}

// ═══════════════════════════════════════════════════════════════
// PURCHASING / SUPPLIERS
// ═══════════════════════════════════════════════════════════════

model Supplier {
  id              String  @id @default(cuid())
  code            String  @unique
  name            String
  // PROSPECT, APPROVED (ASL), CONDITIONAL (incl. trial), DISQUALIFIED — only APPROVED/CONDITIONAL on POs
  status          String  @default("APPROVED")
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  address         String?
  paymentTerms    String  @default("NET30")
  category        String?
  notes           String?
  // Approved Supplier List flag (must be true + status APPROVED/CONDITIONAL for PO)
  isApprovedVendor Boolean @default(false)
  approvedAt      DateTime?
  approvedById    String?
  // Trial path onto ASL when QMS certs missing (per company ASL policy)
  isTrialVendor   Boolean @default(false)
  trialOrdersUsed Int     @default(0)
  trialOrderLimit Int     @default(1)
  // Scorecard metrics (computed/cached)
  onTimeDeliveryPct Float @default(100)
  qualityPpm      Float   @default(0)
  costVariancePct Float   @default(0)
  overallScore    Float   @default(100)
  rating          String  @default("A") // A, B, C, D, F
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrders  PurchaseOrder[]
  purchaseRequests PurchaseRequest[]
  ncrs            NonConformance[]
  scorecardHistory SupplierScorecardHistory[]
  rfqs            Rfq[]
  partVendors     PartVendor[]
  certifications  SupplierCertification[]
  apInvoices      ApInvoice[]

  @@index([isApprovedVendor, status])
}

// Company-level ASL policy: optional QMS cert gates + trial order path
model AslPolicy {
  id                 String  @id @default("default")
  requireIso9001     Boolean @default(false)
  requireAs9100d     Boolean @default(false)
  allowTrialOrders   Boolean @default(true)
  defaultTrialLimit  Int     @default(1)
  notes              String?
  updatedAt          DateTime @updatedAt
}

// QMS / quality system certificates kept on file for suppliers
model SupplierCertification {
  id            String   @id @default(cuid())
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  // ISO9001 | AS9100D | ISO14001 | NADCAP | OTHER
  certType      String
  certNumber    String?
  issuedBy      String?
  issuedAt      DateTime?
  expiresAt     DateTime?
  // Path or URL to stored copy (PDF/image)
  documentUrl   String?
  documentName  String?
  notes         String?
  // VALID | EXPIRED | PENDING | REVOKED
  status        String   @default("VALID")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([supplierId, certType])
  @@index([expiresAt])
}

model SupplierScorecardHistory {
  id              String   @id @default(cuid())
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  period          String   // YYYY-MM
  onTimeDeliveryPct Float
  qualityPpm      Float
  costVariancePct Float
  overallScore    Float
  rating          String
  ncrCount        Int      @default(0)
  poCount         Int      @default(0)
  createdAt       DateTime @default(now())
}

model PurchaseRequest {
  id              String   @id @default(cuid())
  number          String   @unique
  // DRAFT, SUBMITTED (awaiting approvals), APPROVED, REJECTED, CONVERTED, CANCELLED
  status          String   @default("DRAFT")
  requestedById   String?
  department      String?
  neededBy        DateTime?
  justification   String?
  totalEstimate   Float    @default(0)
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  workOrderId     String?
  workOrder       WorkOrder? @relation(fields: [workOrderId], references: [id])
  // Triggered by WI tooling short (shows source WI on PR)
  workInstructionId String?
  workInstruction   WorkInstruction? @relation(fields: [workInstructionId], references: [id])
  // WO_MATERIAL | WI_TOOL | MANUAL | KANBAN | MRB_SCRAP | etc.
  triggerSource   String?
  /// Set when this PR replaces scrapped material from an MRB disposition
  mrbCaseId       String?
  mrbCase         MrbCase? @relation(fields: [mrbCaseId], references: [id], onDelete: SetNull)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id])
  salesOrderId    String?
  // Buyer-confirmed fields before convert
  buyerConfirmedPrices Boolean @default(false)
  buyerConfirmedShip   Boolean @default(false)
  buyerNotes      String?
  approvalPolicyId String?
  approvalPolicy  ApprovalPolicy? @relation(fields: [approvalPolicyId], references: [id])
  currentStepOrder Int     @default(0) // active approval step (0 = none / done)
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lines           PurchaseRequestLine[]
  purchaseOrders  PurchaseOrder[]

  @@index([workOrderId])
  @@index([workInstructionId])
  @@index([status])
}

model PurchaseRequestLine {
  id                String @id @default(cuid())
  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  partId            String?
  description       String
  quantity          Float
  estimatedUnitCost Float  @default(0)
  uom               String @default("EA")
  notes             String?
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  number          String   @unique
  status          String   @default("DRAFT") // DRAFT, APPROVED, ISSUED, ACKNOWLEDGED, PARTIAL_RECEIPT, RECEIVED, INVOICED, CLOSED, CANCELLED
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id])
  purchaseRequestId String?
  purchaseRequest PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id])
  wbsElementId    String?
  wbsElement      WbsElement? @relation(fields: [wbsElementId], references: [id])
  clin            String?  // Contract Line Item Number
  orderDate       DateTime @default(now())
  promisedDate    DateTime? // EDD / expected delivery
  acknowledgedAt  DateTime?
  paymentTerms    String   @default("NET30")
  shippingMethod  String?
  shipToAddress   String?
  totalAmount     Float    @default(0)
  currency        String   @default("USD")
  buyerId         String?
  notes           String?
  // PO procures government property (GFP/CAP) — requires DD Form 1149 at receive
  isGovernmentProperty Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lines           PurchaseOrderLine[]
  receipts        Receipt[]
  inspections     Inspection[]
  apInvoices      ApInvoice[]
  receivingTravelers ReceivingTraveler[]

  @@index([status])
  @@index([supplierId])
  @@index([projectId])
}

// Created when a PO is issued — dock waits here for material to arrive.
// Also used for customer/GFP travelers that are NOT on a purchase order.
// Partial receives create child travelers for the open remainder.
model ReceivingTraveler {
  id              String   @id @default(cuid())
  number          String   @unique
  // PO = purchase order dock; CUSTOMER_GFP = customer-furnished gov property (no PO); DIRECT_GFP = direct GFP receipt
  travelerType    String   @default("PO")
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  // Contract / CLIN for GFP accountability
  contractNumber  String?
  clin            String?
  isGovernmentProperty Boolean @default(false)
  status          String   @default("WAITING") // WAITING, PARTIAL, COMPLETE, CLOSED
  expectedDate    DateTime?
  notes           String?
  shipFromName    String?
  shipFromAddress String?
  // Parent/child split when only part of the PO arrives
  parentId        String?
  parent          ReceivingTraveler?  @relation("TravelerChildren", fields: [parentId], references: [id])
  children        ReceivingTraveler[] @relation("TravelerChildren")
  // Optional snapshot of remaining line qtys at split (JSON: { poLineId, openQty }[])
  openLinesSnapshot String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lines           ReceivingTravelerLine[]
  receipts        Receipt[]

  @@index([status])
  @@index([purchaseOrderId])
  @@index([customerId])
  @@index([parentId])
  @@index([travelerType])
}

// Expected lines on a traveler (required for non-PO GFP; optional snapshot for PO)
model ReceivingTravelerLine {
  id              String @id @default(cuid())
  travelerId      String
  traveler        ReceivingTraveler @relation(fields: [travelerId], references: [id], onDelete: Cascade)
  partId          String?
  part            Part?  @relation(fields: [partId], references: [id])
  description     String
  quantity        Float
  quantityReceived Float @default(0)
  uom             String @default("EA")
  lineNumber      Int    @default(1)
  // COMPANY | GOVERNMENT | CUSTOMER
  ownership       String @default("COMPANY")
  unitCost        Float  @default(0)
  notes           String?
}

model PurchaseOrderLine {
  id              String @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  partId          String?
  part            Part?  @relation(fields: [partId], references: [id])
  description     String
  quantity        Float
  quantityReceived Float @default(0)
  unitCost        Float  @default(0)
  uom             String @default("EA")
  promisedDate    DateTime?
  lineNumber      Int    @default(1)
}

model Receipt {
  id              String   @id @default(cuid())
  number          String   @unique
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  travelerId      String?
  traveler        ReceivingTraveler? @relation(fields: [travelerId], references: [id])
  receivedAt      DateTime @default(now())
  receivedById    String?
  status          String   @default("COMPLETE") // COMPLETE, PARTIAL, DISCREPANCY
  notes           String?
  packingSlip     String?
  // True when DD1149 was required and attached for government property
  dd1149Attached  Boolean  @default(false)

  lines           ReceiptLine[]
}

model ReceiptLine {
  id              String @id @default(cuid())
  receiptId       String
  receipt         Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  poLineId        String?
  travelerLineId  String?
  partId          String?
  description     String
  quantityOrdered Float
  quantityReceived Float
  lotNumber       String?
  serialNumbers   String? // JSON
  unitCost        Float   @default(0)
  ownership       String  @default("COMPANY") // COMPANY, GOVERNMENT, CUSTOMER
}

model Rfq {
  id          String   @id @default(cuid())
  number      String   @unique
  title       String
  status      String   @default("OPEN") // OPEN, CLOSED, AWARDED
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  dueDate     DateTime?
  notes       String?
  createdAt   DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
// ASSET TRACKER (company tools, test equipment, demo units)
// ═══════════════════════════════════════════════════════════════

model Asset {
  id            String   @id @default(cuid())
  assetTag      String   @unique
  name          String
  category      String   @default("EQUIPMENT") // EQUIPMENT, TEST_EQUIPMENT, TOOL, IT, DEMO_UNIT, VEHICLE
  serialNumber  String?
  manufacturer  String?
  model         String?
  /// AVAILABLE | CHECKED_OUT | IN_USE | MAINTENANCE | RETIRED
  status        String   @default("AVAILABLE")
  /// IN_HOUSE_ONLY = must stay on-site; OFFSITE_OK = may leave for demos
  locationScope String   @default("IN_HOUSE_ONLY")
  homeLocation  String?
  purchaseValue Float    @default(0)
  /// Current holder / assignment
  assignedToUserId String?
  assignedToUser   User?  @relation("AssetHolder", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  workOrderId   String?
  workOrder     WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  engTaskId     String?
  engTask       EngTask?   @relation(fields: [engTaskId], references: [id], onDelete: SetNull)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  checkouts     AssetCheckout[]

  @@index([status])
  @@index([category])
}

model AssetCheckout {
  id            String   @id @default(cuid())
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?    @relation("AssetCheckoutUser", fields: [userId], references: [id], onDelete: SetNull)
  checkedOutAt  DateTime @default(now())
  dueAt         DateTime?
  checkedInAt   DateTime?
  purpose       String?
  /// True when the asset physically leaves the facility (demo, field work)
  offsite       Boolean  @default(false)
  destination   String?
  /// Condition note captured at check-in
  returnNote    String?

  @@index([assetId])
}

// ═══════════════════════════════════════════════════════════════
// ACCOUNTING
// ═══════════════════════════════════════════════════════════════

/// A connected bank or credit-card account. Transactions import into
/// the feed and are matched/categorized to journal entries, then
/// reconciled against the linked GL cash/liability account.
model BankAccount {
  id            String   @id @default(cuid())
  name          String
  institution   String?
  /// CHECKING | SAVINGS | CREDIT_CARD
  kind          String   @default("CHECKING")
  last4         String?
  /// Linked GL account (e.g. 1000 Cash, 2050 Credit Card Payable)
  glAccountId   String?
  glAccount     Account? @relation("BankGlAccount", fields: [glAccountId], references: [id])
  /// Running feed balance (from imported transactions)
  currentBalance Float   @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  transactions  BankTransaction[]
}

model BankTransaction {
  id            String      @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  date          DateTime
  description   String
  /// Signed amount: negative = money out, positive = money in
  amount        Float
  /// UNMATCHED | MATCHED | RECONCILED | EXCLUDED
  status        String      @default("UNMATCHED")
  /// GL account this was categorized to
  categoryAccountId String?
  categoryAccount   Account? @relation("BankTxnCategory", fields: [categoryAccountId], references: [id])
  journalEntryId    String?
  externalId    String?     // dedupe key from the import
  createdAt     DateTime    @default(now())

  @@index([bankAccountId, status])
  @@index([externalId])
}

model Account {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  type        String  // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE, COGS
  subtype     String?
  parentCode  String?
  isActive    Boolean @default(true)
  balance     Float   @default(0)
  /// DIRECT | INDIRECT | null — charge code classification for project/overhead cost
  chargeCodeType String?
  /// Optional short charge code label (e.g. DIR-ENG, IND-G&A)
  chargeCode  String?
  description String?

  journalLines JournalLine[]
  partsInventory Part[] @relation("PartInventoryAccount")
  partsExpense   Part[] @relation("PartExpenseAccount")
  partsCogs      Part[] @relation("PartCogsAccount")
  bankAccounts   BankAccount[]     @relation("BankGlAccount")
  bankTxnCategories BankTransaction[] @relation("BankTxnCategory")

  @@index([chargeCodeType])
  @@index([type, isActive])
}

model JournalEntry {
  id          String   @id @default(cuid())
  number      String   @unique
  date        DateTime @default(now())
  description String
  status      String   @default("DRAFT") // DRAFT, PENDING_APPROVAL, POSTED, VOID
  source      String?  // MANUAL, AP, AR, PAYROLL, INVENTORY, WO
  sourceId    String?
  postedAt    DateTime?
  /// Project / charge reference for job cost tracking
  projectId   String?
  chargeCode  String?
  createdById String?
  createdAt   DateTime @default(now())

  lines       JournalLine[]
  attachments JournalAttachment[]
}

model JournalLine {
  id              String @id @default(cuid())
  journalEntryId  String
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId       String
  account         Account @relation(fields: [accountId], references: [id])
  debit           Float  @default(0)
  credit          Float  @default(0)
  memo            String?
  chargeCode      String?
}

/// Receipts / supporting docs on journal entries
model JournalAttachment {
  id              String   @id @default(cuid())
  journalEntryId  String
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  fileName        String?
  url             String
  caption         String?
  /// RECEIPT | INVOICE | SUPPORTING | OTHER
  docType         String   @default("RECEIPT")
  uploadedById    String?
  uploadedAt      DateTime @default(now())

  @@index([journalEntryId])
}

model Customer {
  id            String @id @default(cuid())
  code          String @unique
  name          String
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  billToAddress String?
  shipToAddress String?
  paymentTerms  String @default("NET30")
  creditLimit   Float  @default(0)
  isActive      Boolean @default(true)

  invoices      ArInvoice[]
  salesOrders   SalesOrder[]
  quotes        Quote[]
  receivingTravelers ReceivingTraveler[]
  products      Product[]
}

model ArInvoice {
  id            String   @id @default(cuid())
  number        String   @unique
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  salesOrderId  String?
  invoiceDate   DateTime @default(now())
  dueDate       DateTime?
  status        String   @default("OPEN") // DRAFT, OPEN, PARTIAL, PAID, VOID
  subtotal      Float    @default(0)
  tax           Float    @default(0)
  total         Float    @default(0)
  amountPaid    Float    @default(0)
  notes         String?

  lines         ArInvoiceLine[]
  payments      ArPayment[]
}

model ArInvoiceLine {
  id          String @id @default(cuid())
  invoiceId   String
  invoice     ArInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float  @default(1)
  unitPrice   Float  @default(0)
  amount      Float  @default(0)
}

model ArPayment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     ArInvoice @relation(fields: [invoiceId], references: [id])
  amount      Float
  paymentDate DateTime @default(now())
  method      String   @default("CHECK")
  reference   String?
}

model ApInvoice {
  id              String   @id @default(cuid())
  number          String   @unique
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  invoiceDate     DateTime @default(now())
  dueDate         DateTime?
  status          String   @default("OPEN") // DRAFT, OPEN, PARTIAL, PAID, VOID
  subtotal        Float    @default(0)
  tax             Float    @default(0)
  total           Float    @default(0)
  amountPaid      Float    @default(0)
  notes           String?

  payments        ApPayment[]

  @@index([supplierId])
  @@index([status])
}

model ApPayment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     ApInvoice @relation(fields: [invoiceId], references: [id])
  amount      Float
  paymentDate DateTime @default(now())
  method      String   @default("ACH")
  reference   String?
}

model Budget {
  id          String @id @default(cuid())
  name        String
  fiscalYear  Int
  department  String?
  accountCode String?
  amount      Float
  actual      Float  @default(0)
  period      String? // Q1, Q2, etc or MONTH
}

// ═══════════════════════════════════════════════════════════════
// SALES / SHIPPING
// ═══════════════════════════════════════════════════════════════

model SalesOrder {
  id            String   @id @default(cuid())
  number        String   @unique
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  // OPEN → PLANNED → IN_PRODUCTION → READY_TO_SHIP → SHIPPED → CLOSED
  status        String   @default("OPEN")
  /// Owning department — routes direct-charge timecard approvals
  department    String   @default("PRODUCTION")
  orderDate     DateTime @default(now())
  requiredDate  DateTime? // customer due date
  shipDate      DateTime? // requested / planned ship date
  allowEarlyShip Boolean @default(false)
  shipNotBefore DateTime? // hard earliest ship date when early ship not allowed
  customerPo    String?
  paymentTerms  String   @default("NET30")
  isFob         Boolean  @default(false)
  fobPoint      String?  // e.g. ORIGIN, DESTINATION, plant name
  billToName    String?
  billToAddress String?
  shipToName    String?
  shipToAddress String?
  contactName   String?
  contactEmail  String?
  totalAmount   Float    @default(0)
  // Credit control: when customer is at/over credit limit, deposit is required on the SO
  depositRequired Boolean @default(false)
  depositAmount   Float   @default(0)
  // PENDING | RECEIVED | WAIVED | N_A
  depositStatus   String  @default("N_A")
  creditHold      Boolean @default(false)
  notes         String?
  quoteId       String?  @unique
  quote         Quote?   @relation(fields: [quoteId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lines         SalesOrderLine[]
  shipments     Shipment[]
  workOrders    WorkOrder[]
  traceEvents   TraceEvent[]
  virtualAssets VirtualAsset[]
}

// ═══════════════════════════════════════════════════════════════
// QUOTES (convert → Sales Order on accept)
// ═══════════════════════════════════════════════════════════════

model Quote {
  id            String   @id @default(cuid())
  number        String   @unique
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  // DRAFT → SENT → ACCEPTED | REJECTED | EXPIRED | CONVERTED
  status        String   @default("DRAFT")
  quoteDate     DateTime @default(now())
  validUntil    DateTime?
  requiredDate  DateTime?
  shipDate      DateTime?
  customerPo    String?
  paymentTerms  String   @default("NET30")
  isFob         Boolean  @default(false)
  fobPoint      String?
  billToName    String?
  billToAddress String?
  shipToName    String?
  shipToAddress String?
  contactName   String?
  contactEmail  String?
  totalAmount   Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lines         QuoteLine[]
  salesOrder    SalesOrder?
}

model QuoteLine {
  id          String @id @default(cuid())
  quoteId     String
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  partId      String?
  part        Part?  @relation(fields: [partId], references: [id])
  description String
  quantity    Float
  unitPrice   Float  @default(0)
  lineNumber  Int    @default(1)
}

model SalesOrderLine {
  id            String @id @default(cuid())
  salesOrderId  String
  salesOrder    SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  partId        String?
  part          Part?  @relation(fields: [partId], references: [id])
  description   String
  quantity      Float
  quantityShipped Float @default(0)
  quantityAllocated Float @default(0) // FG stock reserved for this line
  unitPrice     Float  @default(0)
  // OPEN, STOCK_CHECK, ALLOCATED, MAKE_ORDERED, READY, SHIPPED
  fulfillmentStatus String @default("OPEN")
  workOrderId   String?
  workOrders    WorkOrder[]
}

model Shipment {
  id            String   @id @default(cuid())
  number        String   @unique
  salesOrderId  String?
  salesOrder    SalesOrder? @relation(fields: [salesOrderId], references: [id])
  /// Set for return-to-vendor shipments created from an MRB disposition
  mrbCaseId     String?
  mrbCase       MrbCase? @relation(fields: [mrbCaseId], references: [id], onDelete: SetNull)
  status        String   @default("DRAFT") // DRAFT, PICKING, VERIFIED, PACKED, SHIPPED, DELIVERED
  shipDate      DateTime?
  carrier       String?
  trackingNumber String?
  shipToAddress String?
  // Packing flow: verify packing list → pack with photos → ship
  packingListVerified Boolean @default(false)
  verifiedAt    DateTime?
  verifiedById  String?
  packPhotos    String?  // JSON [{url,fileName,caption}]
  packedAt      DateTime?
  packedById    String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lines         ShipmentLine[]
  traceEvents   TraceEvent[]
}

// ═══════════════════════════════════════════════════════════════
// KITTING / TRAVELER SUPPORT
// ═══════════════════════════════════════════════════════════════

model KitOrder {
  id              String   @id @default(cuid())
  number          String   @unique
  workOrderId     String
  workOrder       WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  status          String   @default("OPEN") // OPEN, PICKING, COMPLETE, SHORT, CANCELLED
  pickedById      String?
  notes           String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lines           KitOrderLine[]
  traceEvents     TraceEvent[]

  @@index([workOrderId])
  @@index([status])
}

model KitOrderLine {
  id              String  @id @default(cuid())
  kitOrderId      String
  kitOrder        KitOrder @relation(fields: [kitOrderId], references: [id], onDelete: Cascade)
  partId          String
  part            Part    @relation(fields: [partId], references: [id])
  bomLineId       String?
  quantityRequired Float
  quantityPicked  Float   @default(0)
  inventoryItemId String?
  fromLocationId  String? // chosen pick location when multiple bins
  lotNumber       String?
  serialNumber    String?
  status          String  @default("OPEN") // OPEN, PICKED, SHORT
  notes           String?
}

// Photos captured at receiving / putaway (mock paths OK for demo)
model ReceivingPhoto {
  id              String   @id @default(cuid())
  partId          String?
  part            Part?    @relation(fields: [partId], references: [id])
  receiptId       String?
  receiptLineId   String?
  inventoryItemId String?
  purchaseOrderId String?
  lotNumber       String?
  serialNumber    String?
  url             String   // path or mock data URL
  caption         String?
  takenById       String?
  takenAt         DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([partId])
  @@index([lotNumber])
  @@index([receiptId])
}

// Packing lists, CoC, material certs, GD&T / functional test paperwork
model ReceivingDocument {
  id              String   @id @default(cuid())
  // PACKING_LIST, COC, MATERIAL_CERT, DD1149, VISUAL_DOCS, GDT_DOCS, FUNCTIONAL_TEST, OTHER
  docType         String
  url             String   // data URL or path
  fileName        String?
  caption         String?
  partId          String?
  part            Part?    @relation(fields: [partId], references: [id])
  receiptId       String?
  receiptLineId   String?
  inventoryItemId String?
  purchaseOrderId String?
  inspectionId    String?
  inspection      Inspection? @relation(fields: [inspectionId], references: [id])
  lotNumber       String?
  uploadedById    String?
  uploadedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([docType])
  @@index([receiptId])
  @@index([inspectionId])
  @@index([partId])
}

// End-to-end part genealogy / process history
model TraceEvent {
  id              String   @id @default(cuid())
  eventType       String   // SO_CREATED, STOCK_CHECK, WO_CREATED, PR_CREATED, RECEIPT, PHOTO, INSPECTION, PUTAWAY, KIT, ISSUE, SIGN_OFF, WO_COMPLETE, SHIP, etc.
  partId          String?
  part            Part?    @relation(fields: [partId], references: [id])
  lotNumber       String?
  serialNumber    String?
  quantity        Float?
  fromLocation    String?
  toLocation      String?
  workOrderId     String?
  workOrder       WorkOrder? @relation(fields: [workOrderId], references: [id])
  salesOrderId    String?
  salesOrder      SalesOrder? @relation(fields: [salesOrderId], references: [id])
  purchaseOrderId String?
  kitOrderId      String?
  kitOrder        KitOrder? @relation(fields: [kitOrderId], references: [id])
  shipmentId      String?
  shipment        Shipment? @relation(fields: [shipmentId], references: [id])
  inspectionId    String?
  photoUrls       String?  // JSON
  notes           String?
  metadata        String?  // JSON
  userId          String?
  createdAt       DateTime @default(now())

  @@index([partId])
  @@index([lotNumber])
  @@index([workOrderId])
  @@index([salesOrderId])
  @@index([eventType])
  @@index([createdAt])
}

model ShipmentLine {
  id          String @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  partId      String?
  description String
  quantity    Float
  lotNumber   String?
  serialNumbers String?
}

// ═══════════════════════════════════════════════════════════════
// GOVERNMENT PROPERTY
// ═══════════════════════════════════════════════════════════════

model GovernmentProperty {
  id                String   @id @default(cuid())
  assetTag          String   @unique
  uid               String?  // Unique Item Identifier
  serialNumber      String?
  description       String
  partNumber        String?
  acquisitionCost   Float    @default(0)
  acquisitionDate   DateTime?
  propertyType      String   // GFP, CAP, STE, ST, MATERIAL
  classification    String?  // EQUIPMENT, MATERIAL, REAL_PROPERTY
  status            String   @default("ACTIVE") // ACTIVE, IN_USE, IN_STORAGE, CHECKED_OUT, CONSUMED, DISPOSED, LOST, DAMAGED
  contractNumber    String?
  custodialCode     String?
  location          String?
  inventoryItemId   String?  @unique
  inventoryItem     InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  lastInventoryDate DateTime?
  /// Days between required physical / custodial audits (cycle count)
  auditIntervalDays Int      @default(90)
  nextAuditDue      DateTime?
  condition         String   @default("SERVICEABLE")
  notes             String?
  dfarsCompliant    Boolean  @default(true)
  /// Current checkout holder (null when in storage / available)
  checkedOutToId    String?
  checkedOutTo      User?    @relation("GfpCheckedOut", fields: [checkedOutToId], references: [id], onDelete: SetNull)
  checkedOutAt      DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  complianceChecks  ComplianceCheck[]
  documents         GfpDocument[]
  auditRecords      GfpAuditRecord[]
  checkouts         GfpCheckout[]
  consumptions      GfpConsumption[]

  @@index([contractNumber])
  @@index([status])
  @@index([propertyType])
  @@index([nextAuditDue])
  @@index([checkedOutToId])
}

model ComplianceCheck {
  id          String   @id @default(cuid())
  propertyId  String
  property    GovernmentProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  checkType   String   // PHYSICAL_INVENTORY, CONDITION, DOCUMENTATION, UID_VERIFY
  status      String   // PASS, FAIL, N_A
  checkedById String?
  checkedAt   DateTime @default(now())
  notes       String?
  findings    String?
}

/// DD1149 and other GFP documents attached to property or contract
model GfpDocument {
  id              String   @id @default(cuid())
  /// DD1149 | RECEIPT | TRANSFER | DISPOSAL | OTHER
  docType         String   @default("DD1149")
  fileName        String?
  url             String   // data URL or path
  caption         String?
  contractNumber  String?
  propertyId      String?
  property        GovernmentProperty? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  formNumber      String?  // e.g. DD Form 1149 control number
  formDate        DateTime?
  uploadedById    String?
  uploadedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([docType])
  @@index([contractNumber])
  @@index([propertyId])
}

/// Scheduled / completed GFP cycle audits
model GfpAuditRecord {
  id              String   @id @default(cuid())
  propertyId      String
  property        GovernmentProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  scheduledFor    DateTime
  completedAt     DateTime?
  /// SCHEDULED | COMPLETED | OVERDUE | SKIPPED
  status          String   @default("SCHEDULED")
  result          String?  // PASS | FAIL | N_A
  findings        String?
  notes           String?
  auditedById     String?
  auditedBy       User?    @relation("GfpAuditor", fields: [auditedById], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([propertyId])
  @@index([status])
  @@index([scheduledFor])
}

/// GFP check-out / check-in history (full traceability trail)
model GfpCheckout {
  id              String   @id @default(cuid())
  propertyId      String
  property        GovernmentProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  checkedOutById  String
  checkedOutBy    User     @relation("GfpCheckoutUser", fields: [checkedOutById], references: [id])
  checkedOutAt    DateTime @default(now())
  expectedReturn  DateTime?
  purpose         String?
  checkedInAt     DateTime?
  checkedInById   String?
  checkedInBy     User?    @relation("GfpCheckinUser", fields: [checkedInById], references: [id], onDelete: SetNull)
  checkedInNotes  String?
  /// OPEN | RETURNED | RETURNED_TO_GOVERNMENT | TRANSFERRED_TO_COMPANY
  status          String   @default("OPEN")
  /// How the item left open checkout: CHECKIN | RETURN_TO_GOV | TRANSFER_COMPANY
  disposition     String?
  createdAt       DateTime @default(now())

  @@index([propertyId])
  @@index([checkedOutById])
  @@index([status])
  @@index([checkedOutAt])
}

/// GFP consumption against work orders (requires PM approval)
model GfpConsumption {
  id              String   @id @default(cuid())
  propertyId      String
  property        GovernmentProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  workOrderId     String?
  workOrder       WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  quantity        Float    @default(1)
  reason          String?
  requestedById   String?
  requestedBy     User?    @relation("GfpConsumptionRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  requestedAt     DateTime @default(now())
  /// PENDING_APPROVAL | APPROVED | REJECTED | CONSUMED
  status          String   @default("PENDING_APPROVAL")
  approvedById    String?
  approvedBy      User?    @relation("GfpConsumptionApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  approvalNotes   String?
  consumedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([propertyId])
  @@index([workOrderId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════
// VIRTUAL ASSETS (licenses, downloads, digital items)
// ═══════════════════════════════════════════════════════════════

model VirtualAsset {
  id              String   @id @default(cuid())
  assetTag        String   @unique
  name            String
  description     String?
  /// LICENSE | DOWNLOAD | SUBSCRIPTION | DIGITAL | OTHER
  assetType       String   @default("LICENSE")
  /// AVAILABLE | ASSIGNED | CHECKED_OUT | EXPIRED | RETIRED | SHIPPED
  status          String   @default("AVAILABLE")
  /// INTERNAL | SOLD — internal seats vs customer deliverable licenses
  usageType       String   @default("INTERNAL")
  vendor          String?
  licenseKey      String?
  seats           Int?
  seatsUsed       Int      @default(0)
  cost            Float    @default(0)
  purchasedAt     DateTime?
  expiresAt       DateTime?
  renewalUrl      String?
  notes           String?
  /// Computer / host this seat is installed on
  computerName    String?
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  programId       String?
  program         Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  salesOrderId    String?
  salesOrder      SalesOrder? @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  assignedToId    String?
  assignedTo      User?    @relation("VirtualAssetAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  checkedOutToId  String?
  checkedOutTo    User?    @relation("VirtualAssetCheckout", fields: [checkedOutToId], references: [id], onDelete: SetNull)
  checkedOutAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignments     VirtualAssetAssignment[]

  @@index([status])
  @@index([assetType])
  @@index([usageType])
  @@index([assignedToId])
  @@index([productId])
  @@index([programId])
  @@index([projectId])
  @@index([salesOrderId])
}

model VirtualAssetAssignment {
  id              String   @id @default(cuid())
  virtualAssetId  String
  virtualAsset    VirtualAsset @relation(fields: [virtualAssetId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// ASSIGN | CHECKOUT | RETURN | UNASSIGN
  action          String
  notes           String?
  createdAt       DateTime @default(now())

  @@index([virtualAssetId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
// HR / WORKFORCE
// ═══════════════════════════════════════════════════════════════

model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  sagaId      String?
  saga        Saga?     @relation(fields: [sagaId], references: [id], onDelete: SetNull)
  engTaskId   String?
  engTask     EngTask?  @relation(fields: [engTaskId], references: [id], onDelete: SetNull)
  date        DateTime
  hours       Float
  type        String   @default("REGULAR") // REGULAR, OT, OVERHEAD, PTO, SICK, HOLIDAY, ENG_SCAN
  timesheetId String?
  timesheet   Timesheet? @relation(fields: [timesheetId], references: [id], onDelete: SetNull)
  /// Optional WBS element for project labor distribution
  wbsElementId String?
  wbsElement   WbsElement? @relation(fields: [wbsElementId], references: [id], onDelete: SetNull)
  description String?
  status      String   @default("SUBMITTED") // DRAFT, SUBMITTED, APPROVED, REJECTED
  laborRate   Float    @default(0) // optional $/hr for cost rollup
  costAmount  Float    @default(0) // hours * rate when posted
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([engTaskId])
  @@index([campaignId])
  @@index([date])
}

model PtoRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // PTO, SICK, HOLIDAY, UNPAID
  startDate   DateTime
  endDate     DateTime
  hours       Float
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  reason      String?
  approvedById String?
  createdAt   DateTime @default(now())
}

model ExpenseReport {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  number      String   @unique
  title       String
  status      String   @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED, PAID
  totalAmount Float    @default(0)
  submittedAt DateTime?
  createdAt   DateTime @default(now())

  lines       ExpenseLine[]
}

model ExpenseLine {
  id          String @id @default(cuid())
  reportId    String
  report      ExpenseReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  date        DateTime
  category    String
  description String
  amount      Float
  receiptUrl  String?
}

model PerformanceReview {
  id          String   @id @default(cuid())
  employeeId  String
  employee    User     @relation("ReviewSubject", fields: [employeeId], references: [id])
  reviewerId  String
  reviewer    User     @relation("Reviewer", fields: [reviewerId], references: [id])
  period      String   // 2025-Q1, 2025-Q2, etc
  status      String   @default("DRAFT") // DRAFT, SELF_REVIEW, IN_PROGRESS, AWAITING_SIGNOFF, COMPLETED
  overallRating Float?
  strengths   String?
  improvements String?
  careerNotes String?
  aiSuggestions String?
  /// Review-cycle machinery: question snapshot + employee self-assessment
  dueDate     DateTime?
  questions   String?  // JSON [string] — snapshot of company questions at cycle start
  selfRatings String?  // JSON [{question, rating, comment}] — employee self-grade
  selfSubmittedAt   DateTime?
  employeeSignedAt  DateTime?
  managerSignedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

model EmployeeGoal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  description String?
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  targetDate  DateTime?
  progress    Float    @default(0)
  category    String?  // SKILL, CAREER, PERFORMANCE, CERTIFICATION
  /// Optional company objective this goal rolls up to
  alignedTo   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checkIns    GoalCheckIn[]
}

/// Progress check-in on a goal: a dated note + progress snapshot from
/// the employee or their manager, building the goal's history trail.
model GoalCheckIn {
  id        String       @id @default(cuid())
  goalId    String
  goal      EmployeeGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?        @relation("GoalCheckInAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  /// Progress snapshot at check-in time (0-100)
  progress  Float
  note      String?
  createdAt DateTime     @default(now())

  @@index([goalId])
}

/// Continuous feedback between review cycles — praise or coaching
/// notes that land on the employee's profile as they happen.
model FeedbackNote {
  id          String   @id @default(cuid())
  aboutUserId String
  aboutUser   User     @relation("FeedbackAbout", fields: [aboutUserId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?    @relation("FeedbackAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  kind        String   @default("PRAISE") // PRAISE, COACHING, NOTE
  /// SHARED = employee sees it; MANAGER_ONLY = managers/HR only
  visibility  String   @default("SHARED")
  body        String
  createdAt   DateTime @default(now())

  @@index([aboutUserId])
}

/// Training & qualification record with attachable evidence
/// (certificates, sign-off sheets) — not just a course name.
model TrainingRecord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        String   @default("COURSE") // COURSE, CERTIFICATION, COMPLIANCE, SAFETY, ON_THE_JOB
  provider    String?
  status      String   @default("COMPLETED") // SCHEDULED, IN_PROGRESS, COMPLETED, EXPIRED
  completedAt DateTime?
  expiresAt   DateTime?
  /// JSON [{name,url}] — attached certificates / evidence
  attachments String?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

/// Company-wide payroll & timesheet policy (single row, id="default").
/// Accounting owns this: pay period shape, PTO/sick accrual, holidays.
model PayrollPolicy {
  id                       String   @id @default("default")
  timesheetFrequency       String   @default("WEEKLY") // WEEKLY, BIWEEKLY, SEMIMONTHLY
  weekStartsOn             Int      @default(1) // 0=Sun … 6=Sat (weekly/biweekly)
  /// Anchor date for biweekly period math
  periodAnchor             DateTime @default(now())
  ptoAccrualHoursPerPeriod Float    @default(4)
  sickHoursPerYear         Float    @default(40)
  /// Labor rules: hard cap per day, and where OT / double-OT start
  maxHoursPerDay           Float    @default(14)
  otAfterDailyHours        Float    @default(8)
  dtAfterDailyHours        Float    @default(12)
  otAfterWeeklyHours       Float    @default(40)
  otMultiplier             Float    @default(1.5)
  dtMultiplier             Float    @default(2.0)
  holidays                 String?  // JSON [{date:"2026-12-25", name:"Christmas"}]
  updatedById              String?
  updatedAt                DateTime @updatedAt
}

/// Company review-cycle policy (single row, id="default"). HR owns this.
model ReviewPolicy {
  id                 String   @id @default("default")
  frequencyMonths    Int      @default(12)
  selfReviewLeadDays Int      @default(30)
  questions          String?  // JSON [string] — company-defined review questions
  updatedById        String?
  updatedAt          DateTime @updatedAt
}

/// Company identity & onboarding state (single row, id="default").
/// The setup wizard fills this in; the shell wears the company name.
model CompanySettings {
  id             String   @id @default("default")
  name           String   @default("ForgeRP")
  tagline        String   @default("Manufacturing")
  /// JSON [string] — departments used for org chart + charge routing
  departments    String?
  setupCompleted Boolean  @default(false)
  updatedById    String?
  updatedAt      DateTime @updatedAt
}

/// Accounting system configuration (single row, id="default").
model AccountingSettings {
  id                    String   @id @default("default")
  basis                 String   @default("ACCRUAL") // ACCRUAL, CASH
  fiscalYearStartMonth  Int      @default(1) // 1 = January
  updatedById           String?
  updatedAt             DateTime @updatedAt
}

/// One pay-period timesheet per employee. Entries attach as they are
/// scanned or keyed; submit -> manager approval -> accounting payroll.
model Timesheet {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodStart   DateTime
  periodEnd     DateTime
  status        String   @default("OPEN") // OPEN, SUBMITTED, APPROVED, REJECTED, PROCESSED
  submittedAt   DateTime?
  approvedById  String?
  approvedAt    DateTime?
  processedById String?
  processedAt   DateTime?
  /// Payroll accrual journal entry posted by accounting on processing
  journalEntryId String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entries       TimeEntry[]
  approvals     TimesheetApproval[]

  @@unique([userId, periodStart])
  @@index([status])
}

/// One approval bucket per timesheet submission: PROJECT charges go to
/// the project's PM, DIRECT (WO / department) charges to the department
/// manager, HR (sick / holiday / PTO / overhead) to HR. The sheet
/// finalizes when every bucket approves.
model TimesheetApproval {
  id          String    @id @default(cuid())
  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  category    String    // PROJECT, DIRECT, HR
  refId       String?   // projectId (PROJECT) or department name (DIRECT)
  label       String    // human-readable bucket description
  hours       Float     @default(0)
  approverId  String?
  approver    User?     @relation(fields: [approverId], references: [id], onDelete: SetNull)
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  notes       String?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([approverId, status])
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  kind       String   @default("GENERAL") // OFFER_LETTER, CERTIFICATION, POLICY_ACK, TRAINING, GENERAL
  url        String?
  note       String?
  uploadedAt DateTime @default(now())

  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
// ENGINEERING TRACKERS (JIRA-style)
// ═══════════════════════════════════════════════════════════════

model EngineeringTicket {
  id              String   @id @default(cuid())
  number          String   @unique
  title           String
  description     String?
  type            String   @default("TASK") // EPIC, STORY, TASK, BUG, CHANGE
  status          String   @default("BACKLOG") // BACKLOG, TODO, IN_PROGRESS, IN_REVIEW, DONE, BLOCKED
  priority        String   @default("MEDIUM") // LOWEST, LOW, MEDIUM, HIGH, CRITICAL
  /// SYSTEMS | MECHANICAL | ELECTRICAL | NETWORK | CYBER | SOFTWARE | HARDWARE | RF | QUALITY | OTHER
  discipline      String?
  assigneeId      String?
  assignee        User?    @relation("TicketAssignee", fields: [assigneeId], references: [id])
  createdById     String?
  createdBy       User?    @relation("TicketCreator", fields: [createdById], references: [id])
  projectId       String?
  sprintId        String?
  sprint          Sprint?  @relation(fields: [sprintId], references: [id])
  storyPoints     Int?
  labels          String?  // JSON
  linkedBomId     String?
  linkedWiId      String?
  linkedCrId      String?
  linkedPoId      String?
  /// Optional bridge to new Campaign/Saga hierarchy
  campaignId      String?
  sagaId          String?
  engTaskId       String?
  dueDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  comments        TicketComment[]

  @@index([status])
  @@index([assigneeId])
  @@index([discipline])
}

model Sprint {
  id          String    @id @default(cuid())
  name        String
  goal        String?
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("PLANNED") // PLANNED, ACTIVE, COMPLETED

  tickets     EngineeringTicket[]
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    EngineeringTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String?
  body      String
  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
// VALUE STREAM / METRICS CACHE
// ═══════════════════════════════════════════════════════════════

model ValueStreamMetric {
  id          String   @id @default(cuid())
  stage       String   // SUPPLIER, PO, RECEIVING, INSPECTION, MRB, INVENTORY, PRODUCTION, SHIPPING
  metricKey   String
  metricValue Float
  unit        String?
  period      String?  // daily snapshot date
  metadata    String?  // JSON
  recordedAt  DateTime @default(now())

  @@index([stage, metricKey])
}

// Plant stations:
// MANUFACTURING | QA | TEST | SHIPPING | RECEIVING
model WorkCenter {
  id              String @id @default(cuid())
  code            String @unique
  name            String
  // MANUFACTURING | QA | TEST | SHIPPING | RECEIVING
  area            String @default("MANUFACTURING")
  department      String?
  capacityHoursPerDay Float @default(16)
  efficiency      Float  @default(0.85)
  isActive        Boolean @default(true)
  isDefault       Boolean @default(false) // default station when routing by area only
  sortOrder       Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  staff           WorkCenterStaff[]

  @@index([area, isActive])
}

/// People assigned to a work center for capacity planning
model WorkCenterStaff {
  id              String   @id @default(cuid())
  workCenterId    String
  workCenter      WorkCenter @relation(fields: [workCenterId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hoursPerDay     Float    @default(8)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@unique([workCenterId, userId])
  @@index([userId])
}
