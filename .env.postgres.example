# PostgreSQL (docker-compose)
DATABASE_URL="postgresql://forgeerp:forgeerp@localhost:5432/forgeerp?schema=public"
# Direct (non-pooled) connection for `prisma db push` / migrate. Same as
# DATABASE_URL unless you front the app with a pooler (e.g. Supabase 6543).
DIRECT_URL="postgresql://forgeerp:forgeerp@localhost:5432/forgeerp?schema=public"

# Optional: xAI Grok for AI Assistant
# XAI_API_KEY=xai-...
# XAI_MODEL=grok-2-latest

# Demo user role hint
# DEMO_USER_ROLE=ADMIN
