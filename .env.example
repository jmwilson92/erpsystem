# SQLite (default zero-config local dev)
DATABASE_URL="file:./prisma/dev.db"

# Optional: xAI Grok for AI Assistant upgrade path
# XAI_API_KEY=xai-...
# XAI_MODEL=grok-2-latest

# Demo auth role (ADMIN, ENGINEERING, QUALITY, PURCHASING, PRODUCTION, etc.)
DEMO_USER_ROLE=ADMIN

# Auth mode:
#   unset / anything but "0" → evaluation (persona switcher open)
#   DEMO_MODE=0             → production (login required)
# DEMO_MODE=0

# Production plant deploys: also see .env.production.example

# ── Subscription billing (Stripe) — optional; unset = in-app activation ──
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...     # annual price IDs per plan
# STRIPE_PRICE_GROWTH=price_...
# STRIPE_PRICE_BUSINESS=price_...
# APP_URL=https://your-instance.example   # for checkout success/cancel URLs

# ── Guided-tour voice (TTS) — optional; unset = browser speech synthesis ──
# TTS_API_URL=https://api.x.ai/v1/audio/speech   # any OpenAI-compatible TTS
# TTS_API_KEY=...                                 # falls back to XAI_API_KEY
# TTS_MODEL=tts-1
# TTS_VOICE=alloy
